  <!-- Enables consuming WinRT (Windows.Gaming.Input) from this classic .NET FW WPF app so PlayStation
       (DualSense/DualShock) + Xbox controllers work natively over USB/Bluetooth without extra software.
       Pick whichever Windows SDK UnionMetadata is installed so the build is portable (dev box vs CI runner). -->
  <PropertyGroup>
    <VortexUM>$(MSBuildProgramFiles32)\Windows Kits\10\UnionMetadata</VortexUM>
    <TargetPlatformVersion Condition="Exists('$(VortexUM)\10.0.26100.0\Windows.winmd')">10.0.26100.0</TargetPlatformVersion>
    <TargetPlatformVersion Condition="'$(TargetPlatformVersion)'=='' And Exists('$(VortexUM)\10.0.22621.0\Windows.winmd')">10.0.22621.0</TargetPlatformVersion>
    <TargetPlatformVersion Condition="'$(TargetPlatformVersion)'=='' And Exists('$(VortexUM)\10.0.22000.0\Windows.winmd')">10.0.22000.0</TargetPlatformVersion>
    <TargetPlatformVersion Condition="'$(TargetPlatformVersion)'=='' And Exists('$(VortexUM)\10.0.20348.0\Windows.winmd')">10.0.20348.0</TargetPlatformVersion>
    <TargetPlatformVersion Condition="'$(TargetPlatformVersion)'=='' And Exists('$(VortexUM)\10.0.19041.0\Windows.winmd')">10.0.19041.0</TargetPlatformVersion>
    <VortexWinMd>$(VortexUM)\$(TargetPlatformVersion)\Windows.winmd</VortexWinMd>
  </PropertyGroup>
