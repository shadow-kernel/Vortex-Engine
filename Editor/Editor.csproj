  <!-- Ship the project templates (git submodule under ..\Templates) next to the editor exe so the
       "Create New Project" dialog can discover them at runtime via AppDir\Templates. -->
  <Target Name="CopyProjectTemplates" AfterTargets="Build" Condition="Exists('$(SolutionDir)Templates')">
    <ItemGroup>
      <TemplateFiles Include="$(SolutionDir)Templates\**\*.*"
                     Exclude="$(SolutionDir)Templates\**\.git\**;$(SolutionDir)Templates\**\bin\**;$(SolutionDir)Templates\**\obj\**;$(SolutionDir)Templates\**\Library\**;$(SolutionDir)Templates\**\Build\**;$(SolutionDir)Templates\**\.vs\**" />
    </ItemGroup>
    <Copy SourceFiles="@(TemplateFiles)"
          DestinationFiles="@(TemplateFiles->'$(OutDir)Templates\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>
