<Window x:Class="Editor.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" WindowStartupLocation="CenterScreen"
        Width="560" Height="360" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Window.Resources>
        <LinearGradientBrush x:Key="VortexBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8E7CFF" Offset="0"/>
            <GradientStop Color="#6C5CE7" Offset="0.55"/>
            <GradientStop Color="#34D3E6" Offset="1"/>
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="VortexCore">
            <GradientStop Color="#F2EFFF" Offset="0"/>
            <GradientStop Color="#9D8BFF" Offset="0.6"/>
            <GradientStop Color="#6C5CE7" Offset="1"/>
        </RadialGradientBrush>
    </Window.Resources>

    <Border Background="#161618" CornerRadius="18" BorderBrush="#2C2C32" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.6" BlurRadius="34" ShadowDepth="0"/>
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Ellipse Width="420" Height="420" VerticalAlignment="Top" Margin="0,-160,0,0" Opacity="0.55" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3C3088" Offset="0"/>
                        <GradientStop Color="#00161618" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-12,0,0">
                <Viewbox Width="92" Height="92" HorizontalAlignment="Center">
                    <Canvas Width="160" Height="160">
                        <Path Fill="{StaticResource VortexBrush}" Data="M80,80 C74,48 96,22 130,24 C113,44 113,65 80,80 Z"/>
                        <Path Fill="{StaticResource VortexBrush}" Data="M80,80 C74,48 96,22 130,24 C113,44 113,65 80,80 Z">
                            <Path.RenderTransform><RotateTransform Angle="120" CenterX="80" CenterY="80"/></Path.RenderTransform>
                        </Path>
                        <Path Fill="{StaticResource VortexBrush}" Data="M80,80 C74,48 96,22 130,24 C113,44 113,65 80,80 Z">
                            <Path.RenderTransform><RotateTransform Angle="240" CenterX="80" CenterY="80"/></Path.RenderTransform>
                        </Path>
                        <Ellipse Canvas.Left="69" Canvas.Top="69" Width="22" Height="22" Fill="{StaticResource VortexCore}"/>
                    </Canvas>
                </Viewbox>
                <TextBlock Text="Vortex Engine" FontSize="32" FontWeight="Bold" Foreground="#F5F5F7"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
                <TextBlock Text="Real-time Game Engine" FontSize="13" Foreground="#73737A"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel VerticalAlignment="Bottom" Margin="44,0,44,30">
                <ProgressBar x:Name="Bar" Minimum="0" Maximum="100" Value="0" Height="5"
                             Background="#26262B" BorderThickness="0" Foreground="{StaticResource VortexBrush}"/>
                <Grid Margin="0,12,0,0">
                    <TextBlock x:Name="StatusText" Text="Starting…" Foreground="#9A9AA1" FontSize="12"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PercentText" Text="" Foreground="#8E7CFF" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
