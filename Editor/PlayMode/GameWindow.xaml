<Window x:Class="Editor.PlayMode.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gp="clr-namespace:Editor.Editors.WorldEditor.Components.GamePreview"
        Title="Vortex — Play" Width="1280" Height="760"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#161618" UseLayoutRounding="True"
        TextOptions.TextRenderingMode="ClearType">
    <Border Background="#161618" BorderBrush="#3A3A3E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#202023" MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#32D74B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="PLAYING" Margin="9,0,0,0"
                               Foreground="#F5F5F7" FontSize="12" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Text, Segoe UI" VerticalAlignment="Center"/>
                    <Border Width="1" Height="16" Background="#3A3A3E" Margin="14,0"/>
                    <TextBlock Text="Vortex Engine — Game" Foreground="#98989F" FontSize="12"
                               FontFamily="Segoe UI Variable Text, Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button x:Name="PauseBtn" Content="❚❚  Pause" Style="{DynamicResource Vortex.Button.Ghost}"
                            Height="28" Padding="14,0" Margin="0,0,8,0" Click="Pause_Click"/>
                    <Button x:Name="StopBtn" Content="■  Stop" Style="{DynamicResource Vortex.Button.Accent}"
                            Height="28" Padding="16,0" Click="Stop_Click"/>
                </StackPanel>
            </Grid>

            <!-- Engine viewport -->
            <Border Grid.Row="1" Background="#0E0E10">
                <gp:ViewportHost x:Name="GameViewportHost"/>
            </Border>
        </Grid>
    </Border>
</Window>
