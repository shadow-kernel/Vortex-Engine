<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors -->
    <Color x:Key="MenuBackgroundColor">#1E1E1E</Color>
    <Color x:Key="MenuBorderColor">#454545</Color>
    <Color x:Key="MenuForegroundColor">#E0E0E0</Color>
    <Color x:Key="MenuHighlightColor">#6C5CE7</Color>
    <Color x:Key="MenuSeparatorColor">#454545</Color>
    <Color x:Key="MenuDisabledColor">#656565</Color>

    <SolidColorBrush x:Key="Menu.Static.Background" Color="{StaticResource MenuBackgroundColor}"/>
    <SolidColorBrush x:Key="Menu.Static.Border" Color="{StaticResource MenuBorderColor}"/>
    <SolidColorBrush x:Key="Menu.Static.Foreground" Color="{StaticResource MenuForegroundColor}"/>
    <SolidColorBrush x:Key="Menu.Static.Separator" Color="{StaticResource MenuSeparatorColor}"/>
    <SolidColorBrush x:Key="Menu.Disabled.Foreground" Color="{StaticResource MenuDisabledColor}"/>
    <SolidColorBrush x:Key="MenuItem.Selected.Background" Color="{StaticResource MenuHighlightColor}"/>
    <SolidColorBrush x:Key="MenuItem.Selected.Border" Color="{StaticResource MenuHighlightColor}"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Background" Color="{StaticResource MenuHighlightColor}"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Disabled.Background" Color="#0A0A0A"/>

    <!-- Context Menu Style -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Grid.IsSharedSizeScope" Value="True"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Foreground" Value="{StaticResource Menu.Static.Foreground}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border x:Name="Border" 
                            Background="{StaticResource Menu.Static.Background}"
                            BorderBrush="{StaticResource Menu.Static.Border}"
                            BorderThickness="1" 
                            CornerRadius="4" 
                            Padding="2,4">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="3" Opacity="0.6" BlurRadius="10" Direction="270"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Top Level Header Template (for MenuBar items) -->
    <ControlTemplate x:Key="{x:Static MenuItem.TopLevelHeaderTemplateKey}" TargetType="{x:Type MenuItem}">
        <Border x:Name="Border" Background="Transparent" BorderThickness="0" Padding="8,4">
            <Grid>
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsSubmenuOpen}" 
                       AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                    <Border x:Name="SubmenuBorder" SnapsToDevicePixels="True"
                            Background="{StaticResource Menu.Static.Background}"
                            BorderBrush="{StaticResource Menu.Static.Border}"
                            BorderThickness="1" CornerRadius="4" Padding="2,4">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="3" Opacity="0.6" BlurRadius="10" Direction="270"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuItem.Highlight.Background}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Submenu Item Template (items inside a menu) -->
    <ControlTemplate x:Key="{x:Static MenuItem.SubmenuItemTemplateKey}" TargetType="{x:Type MenuItem}">
        <Border x:Name="Border" Background="Transparent" CornerRadius="3" 
                Padding="8,6" Margin="2,0" SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24" SharedSizeGroup="Icon"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                    <ColumnDefinition Width="16"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <ContentPresenter x:Name="Icon" Grid.Column="0" ContentSource="Icon"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  Width="16" Height="16"/>

                <!-- Checkmark -->
                <Border x:Name="Check" Grid.Column="0" Visibility="Collapsed"
                        Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                               Foreground="#4EC9B0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Header -->
                <ContentPresenter x:Name="HeaderHost" Grid.Column="1" ContentSource="Header"
                                  VerticalAlignment="Center" RecognizesAccessKey="True"/>

                <!-- Shortcut -->
                <TextBlock x:Name="InputGestureText" Grid.Column="2"
                           Text="{TemplateBinding InputGestureText}"
                           Foreground="#707070" FontSize="11"
                           VerticalAlignment="Center" Margin="24,0,0,0"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="Icon" Value="{x:Null}">
                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsCheckable" Value="True">
                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="Check" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuItem.Highlight.Background}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource Menu.Disabled.Foreground}"/>
                <Setter TargetName="Icon" Property="Opacity" Value="0.5"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Submenu Header Template (items with children/submenus) -->
    <ControlTemplate x:Key="{x:Static MenuItem.SubmenuHeaderTemplateKey}" TargetType="{x:Type MenuItem}">
        <Border x:Name="Border" Background="Transparent" CornerRadius="3" 
                Padding="8,6" Margin="2,0" SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24" SharedSizeGroup="Icon"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                    <ColumnDefinition Width="16"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <ContentPresenter x:Name="Icon" Grid.Column="0" ContentSource="Icon"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  Width="16" Height="16"/>

                <!-- Header -->
                <ContentPresenter x:Name="HeaderHost" Grid.Column="1" ContentSource="Header"
                                  VerticalAlignment="Center" RecognizesAccessKey="True"/>

                <!-- Arrow -->
                <TextBlock Grid.Column="3" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" 
                           FontSize="10" Foreground="#808080"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>

                <!-- Submenu Popup -->
                <Popup x:Name="Popup" Placement="Right" IsOpen="{TemplateBinding IsSubmenuOpen}"
                       AllowsTransparency="True" Focusable="False" PopupAnimation="Fade"
                       HorizontalOffset="0" VerticalOffset="-6">
                    <Border x:Name="SubmenuBorder" SnapsToDevicePixels="True"
                            Background="{StaticResource Menu.Static.Background}"
                            BorderBrush="{StaticResource Menu.Static.Border}"
                            BorderThickness="1" CornerRadius="4" Padding="2,4">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="3" Opacity="0.6" BlurRadius="10" Direction="270"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="Icon" Value="{x:Null}">
                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuItem.Highlight.Background}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource Menu.Disabled.Foreground}"/>
                <Setter TargetName="Icon" Property="Opacity" Value="0.5"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- MenuItem Style that uses the correct template based on Role -->
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="{StaticResource Menu.Static.Foreground}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.TopLevelHeaderTemplateKey}}"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
                <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.SubmenuItemTemplateKey}}"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.SubmenuHeaderTemplateKey}}"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuItem">
                <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.SubmenuItemTemplateKey}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Separator Style for Menus -->
    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="{x:Type Separator}">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="28,4,8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Background="{StaticResource Menu.Static.Separator}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- General Separator Style -->
    <Style TargetType="{x:Type Separator}">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="28,4,8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Background="{StaticResource Menu.Static.Separator}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
