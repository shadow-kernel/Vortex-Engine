<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================== -->
    <!--  VORTEX DESIGN SYSTEM  ·  modern, Apple-inspired dark theme     -->
    <!-- ============================================================== -->

    <!-- Typography -->
    <FontFamily x:Key="Vortex.Font">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Vortex.Font.Display">Segoe UI Variable Display, Segoe UI Semibold, Segoe UI</FontFamily>
    <sys:Double x:Key="Vortex.Radius">8</sys:Double>

    <!-- Palette (macOS-dark inspired surfaces + brand indigo accent) -->
    <Color x:Key="Vortex.Color.Bg">#FF161618</Color>
    <Color x:Key="Vortex.Color.Surface">#FF202023</Color>
    <Color x:Key="Vortex.Color.SurfaceAlt">#FF2A2A2E</Color>
    <Color x:Key="Vortex.Color.SurfaceHover">#FF323237</Color>
    <Color x:Key="Vortex.Color.Border">#FF3A3A3E</Color>
    <Color x:Key="Vortex.Color.BorderSoft">#FF2E2E32</Color>
    <Color x:Key="Vortex.Color.Text">#FFF5F5F7</Color>
    <Color x:Key="Vortex.Color.TextDim">#FF98989F</Color>
    <Color x:Key="Vortex.Color.TextFaint">#FF6A6A70</Color>
    <Color x:Key="Vortex.Color.Accent">#FF6C5CE7</Color>
    <Color x:Key="Vortex.Color.AccentHover">#FF7E70EE</Color>
    <Color x:Key="Vortex.Color.AccentPressed">#FF5B4BD6</Color>
    <Color x:Key="Vortex.Color.Danger">#FFFF453A</Color>
    <Color x:Key="Vortex.Color.Success">#FF32D74B</Color>
    <Color x:Key="Vortex.Color.Warn">#FFFFD60A</Color>

    <SolidColorBrush x:Key="Vortex.Bg"           Color="{StaticResource Vortex.Color.Bg}"/>
    <SolidColorBrush x:Key="Vortex.Surface"      Color="{StaticResource Vortex.Color.Surface}"/>
    <SolidColorBrush x:Key="Vortex.SurfaceAlt"   Color="{StaticResource Vortex.Color.SurfaceAlt}"/>
    <SolidColorBrush x:Key="Vortex.SurfaceHover" Color="{StaticResource Vortex.Color.SurfaceHover}"/>
    <SolidColorBrush x:Key="Vortex.Border"       Color="{StaticResource Vortex.Color.Border}"/>
    <SolidColorBrush x:Key="Vortex.BorderSoft"   Color="{StaticResource Vortex.Color.BorderSoft}"/>
    <SolidColorBrush x:Key="Vortex.Text"         Color="{StaticResource Vortex.Color.Text}"/>
    <SolidColorBrush x:Key="Vortex.TextDim"      Color="{StaticResource Vortex.Color.TextDim}"/>
    <SolidColorBrush x:Key="Vortex.TextFaint"    Color="{StaticResource Vortex.Color.TextFaint}"/>
    <SolidColorBrush x:Key="Vortex.Accent"       Color="{StaticResource Vortex.Color.Accent}"/>
    <SolidColorBrush x:Key="Vortex.AccentHover"  Color="{StaticResource Vortex.Color.AccentHover}"/>
    <SolidColorBrush x:Key="Vortex.AccentPressed" Color="{StaticResource Vortex.Color.AccentPressed}"/>
    <SolidColorBrush x:Key="Vortex.Danger"       Color="{StaticResource Vortex.Color.Danger}"/>
    <SolidColorBrush x:Key="Vortex.Success"      Color="{StaticResource Vortex.Color.Success}"/>

    <!-- Accent gradient for hero buttons / highlights -->
    <LinearGradientBrush x:Key="Vortex.AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF7E70EE" Offset="0"/>
        <GradientStop Color="#FF5B4BD6" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================================== -->
    <!--  Thin, smooth scrollbars (implicit)                            -->
    <!-- ============================================================== -->
    <Style x:Key="Vortex.ScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="t" CornerRadius="4" Background="#55FFFFFF" Margin="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="t" Property="Background" Value="#88FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="t" Property="Background" Value="#AAFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="11"/>
        <Setter Property="MinWidth" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid x:Name="root" Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Vortex.ScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" IsTabStop="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" IsTabStop="False"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="Height" Value="11"/>
                            <Setter Property="MinHeight" Value="11"/>
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================== -->
    <!--  Rounded, soft-shadow tooltips (implicit)                      -->
    <!-- ============================================================== -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{StaticResource Vortex.SurfaceAlt}"
                            BorderBrush="{StaticResource Vortex.Border}"
                            BorderThickness="1" CornerRadius="8" Padding="11,7">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.5" Color="Black"/>
                        </Border.Effect>
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================== -->
    <!--  Buttons                                                       -->
    <!-- ============================================================== -->
    <!-- Accent / primary button -->
    <Style x:Key="Vortex.Button.Accent" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd" CornerRadius="8" Background="{StaticResource Vortex.AccentGradient}"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.45" Color="#6C5CE7"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Vortex.AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Vortex.AccentPressed}"/>
                            <Setter TargetName="bd" Property="RenderTransform">
                                <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98"/></Setter.Value>
                            </Setter>
                            <Setter TargetName="bd" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost / secondary button -->
    <Style x:Key="Vortex.Button.Ghost" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd" CornerRadius="8" Background="{StaticResource Vortex.SurfaceAlt}"
                            BorderBrush="{StaticResource Vortex.Border}" BorderThickness="1"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Vortex.SurfaceHover}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Vortex.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Vortex.Surface}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================== -->
    <!--  TextBox                                                       -->
    <!-- ============================================================== -->
    <Style x:Key="Vortex.TextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Vortex.Accent}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="bd" CornerRadius="8" Background="{StaticResource Vortex.Bg}"
                            BorderBrush="{StaticResource Vortex.Border}" BorderThickness="1" Padding="10,0">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Vortex.TextFaint}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Vortex.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================== -->
    <!--  Surfaces & text                                               -->
    <!-- ============================================================== -->
    <!-- Card: elevated rounded surface -->
    <Style x:Key="Vortex.Card" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource Vortex.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Vortex.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.35" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vortex.Text.Title" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font.Display}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Vortex.Text.Section" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.TextDim}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <Style x:Key="Vortex.Text.Body" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Pill / status chip -->
    <Style x:Key="Vortex.Chip" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource Vortex.SurfaceAlt}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ============================================================== -->
    <!--  Dark ComboBox (implicit) — replaces the white WPF default      -->
    <!--  everywhere (inspector dropdowns, camera/tag/layer selectors).  -->
    <!-- ============================================================== -->
    <Style x:Key="Vortex.ComboToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="bd" CornerRadius="7"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" SnapsToDevicePixels="True">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   Foreground="{StaticResource Vortex.TextDim}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Vortex.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Vortex.ComboBox" TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="Background" Value="{StaticResource Vortex.SurfaceAlt}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Vortex.Border}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="11,0,28,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Style="{StaticResource Vortex.ComboToggle}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" HorizontalAlignment="Left"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        <Popup x:Name="Popup" Placement="Bottom" Focusable="False" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder" Margin="0,4,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource Vortex.Surface}"
                                    BorderBrush="{StaticResource Vortex.Border}" BorderThickness="1" CornerRadius="8">
                                <ScrollViewer SnapsToDevicePixels="True" Padding="2">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Vortex.TextFaint}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- App-wide default: any ComboBox without an explicit style gets the dark look. -->
    <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource Vortex.ComboBox}"/>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="b" Background="Transparent" CornerRadius="5"
                            Padding="{TemplateBinding Padding}" Margin="2,1" SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Vortex.SurfaceHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Vortex.SurfaceHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================== -->
    <!--  Dark CheckBox (implicit) — replaces the white WPF default       -->
    <!-- ============================================================== -->
    <Style x:Key="Vortex.CheckBox" TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource Vortex.Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource Vortex.Font}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="box" Width="18" Height="18" CornerRadius="5"
                                Background="{StaticResource Vortex.SurfaceAlt}"
                                BorderBrush="{StaticResource Vortex.Border}" BorderThickness="1"
                                VerticalAlignment="Center" SnapsToDevicePixels="True">
                            <TextBlock x:Name="check" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter x:Name="cp" Margin="8,0,0,0" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource Vortex.Accent}"/>
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Vortex.Accent}"/>
                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Vortex.Accent}"/>
                        </Trigger>
                        <Trigger Property="HasContent" Value="False">
                            <Setter TargetName="cp" Property="Margin" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource Vortex.CheckBox}"/>

    <!-- ============================================================== -->
    <!--  Dark Slider (implicit) — thin track, accent fill, round thumb -->
    <!-- ============================================================== -->
    <Style x:Key="Vortex.SliderThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Width" Value="15"/>
        <Setter Property="Height" Value="15"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Ellipse Fill="White" SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="Vortex.SliderRepeat" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type Slider}">
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Foreground" Value="{StaticResource Vortex.Accent}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid VerticalAlignment="Center">
                        <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                                Background="{StaticResource Vortex.SurfaceAlt}"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" IsTabStop="False" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                                                    Background="{StaticResource Vortex.Accent}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Vortex.SliderThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource Vortex.SliderRepeat}" Command="{x:Static Slider.IncreaseLarge}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
