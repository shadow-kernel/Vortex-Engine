<Window x:Class="Editor.Project.ProjectBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Editor.Project"
        mc:Ignorable="d"
        Background="#0F141C"
        Icon="{DynamicResource AppIcon}"
        Title="Project Browser - Vortex Engine" Height="520" Width="880"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Assets/Images/ImageResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="TabToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="BackgroundBorder" Background="Transparent" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="Underline" Background="#2B7CEB" Height="3" VerticalAlignment="Bottom" Margin="10,0,10,-1" Opacity="0" CornerRadius="3"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#10FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#18FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#14FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#80FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="80,-10,80,0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="{DynamicResource AppIcon}" Width="40" Height="40" HorizontalAlignment="Left" Grid.Column="0"/>

            <Border Grid.Column="1" Width="1" Height="40" Background="White" VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="Project Browser - Vortex Engine"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Foreground="White"/>
        </Grid>

        <Border Grid.Row="0"
                Height="1"
                VerticalAlignment="Bottom"
                Margin="40,10,40,10"
                Background="White"
                />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <ToggleButton Content="Create New Project" Width="170" Height="44" Margin="0,0,12,8"
                    x:Name="createProjectButton" Click="OnToggleButtonClick" Style="{StaticResource TabToggleButtonStyle}"/>
            <ToggleButton Content="Open Existing Project" Width="170" Height="44" Margin="0,0,0,8"
                    x:Name="openProjectButton" Click="OnToggleButtonClick" Style="{StaticResource TabToggleButtonStyle}"/>
        </StackPanel>
        <Grid Grid.Row="2" Margin="40,0,40,20" x:Name="browserContent">
            <local:NewProjectView x:Name="newProjectView" Visibility="Collapsed" />
            <local:OpenProjectView x:Name="openProjectView" />
        </Grid>
    </Grid>
</Window>
