<Window x:Class="Editor.Project.Projection.ProjectSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Project Settings" Width="640" Height="620"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="#161618" UseLayoutRounding="True"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9A9AA1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background" Value="#202023"/>
            <Setter Property="Foreground" Value="#F5F5F7"/>
            <Setter Property="BorderBrush" Value="#3A3A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#6C5CE7"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9C8CFF"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1B1B1E"/>
            <Setter Property="BorderBrush" Value="#2C2C32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="Pill" TargetType="Button">
            <Setter Property="Background" Value="#26262B"/>
            <Setter Property="Foreground" Value="#E9E9ED"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" BorderBrush="#3A3A42" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#33333A"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Accent" TargetType="Button" BasedOn="{StaticResource Pill}">
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#7d6ef0"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#161618" BorderBrush="#2C2C32" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A1A1C">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#9C8CFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Project Settings" Foreground="#F5F5F7" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProjLabel" Foreground="#73737A" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11" Click="Close_Click"
                        HorizontalAlignment="Right" Width="40" Height="40" Background="Transparent" Foreground="#C8C8CE"
                        BorderThickness="0" Cursor="Hand" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,16">
                <StackPanel>
                    <!-- General -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="GENERAL" Style="{StaticResource Section}"/>
                            <TextBlock Text="Project name" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="NameBox" Style="{StaticResource Field}"/>
                            <TextBlock Text="Location" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="PathBox" Style="{StaticResource Field}" IsReadOnly="True" Foreground="#9A9AA1"/>
                        </StackPanel>
                    </Border>

                    <!-- Git / Source Control -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="GIT / SOURCE CONTROL" Style="{StaticResource Section}"/>
                            <TextBlock Text="Remote (origin) URL" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="RemoteBox" Style="{StaticResource Field}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Commit author — name" Style="{StaticResource Lbl}"/>
                                    <TextBox x:Name="UserNameBox" Style="{StaticResource Field}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Commit author — email" Style="{StaticResource Lbl}"/>
                                    <TextBox x:Name="UserEmailBox" Style="{StaticResource Field}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Current branch:" Foreground="#73737A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="BranchLabel" Text="—" Foreground="#E9E9ED" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,18,0"/>
                                <TextBlock Text="Git LFS:" Foreground="#73737A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LfsLabel" Text="—" Foreground="#E9E9ED" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Build -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="BUILD" Style="{StaticResource Section}"/>
                            <TextBlock Text="Target platform: Windows (x64). More build settings coming soon."
                                       Foreground="#73737A" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#1A1A1C" BorderBrush="#2C2C32" BorderThickness="0,1,0,0">
                <Grid Margin="18,0">
                    <TextBlock x:Name="StatusText" Text="" Foreground="#9A9AA1" FontSize="11.5" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Close" Style="{StaticResource Pill}" Click="Close_Click" Margin="0,0,10,0"/>
                        <Button Content="Save" Style="{StaticResource Accent}" Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
