<UserControl x:Class="Editor.Project.Projection.NewProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Editor.Project.Projection"
             xmlns:model="clr-namespace:Editor.Project.Model"
             d:DataContext="{d:DesignData Type=model:NewProjectModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d" MinWidth="760" MinHeight="540"
             d:DesignHeight="470" d:DesignWidth="820"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#1A1A1C"/>
        <SolidColorBrush x:Key="CardBackground" Color="#212124"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#33333A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6C5CE7"/>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C8C8CE"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#28282C"/>
            <Setter Property="Foreground" Value="#E9E9ED"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="CaretBrush" Value="#6C5CE7"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#44444C"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#28282C"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E5FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33333A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#7D6EF0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5A49D6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Background" Value="#28282C"/>
            <Setter Property="Foreground" Value="#E9E9ED"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" CornerRadius="7" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33333A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template list card -->
        <Style x:Key="TemplateItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="#211F26" CornerRadius="9"
                                BorderBrush="#2C2C33" BorderThickness="1" Padding="12,11">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="8" Background="#312B4A" Margin="0,0,11,0">
                                    <TextBlock Text="&#xE809;" FontFamily="Segoe MDL2 Assets" FontSize="17"
                                               Foreground="#B4A7FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Foreground="#F0F0F3" FontSize="13.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Tagline}" Foreground="#82828B" FontSize="11" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#27242F"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#3A3550"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#2A2547"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource CardBackground}" CornerRadius="12"
            BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="18,18,18,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="248"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: template picker -->
                <DockPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock DockPanel.Dock="Top" Text="CHOOSE A TEMPLATE" Foreground="#6E6E77"
                               FontSize="10.5" FontWeight="SemiBold" Margin="2,0,0,10"/>
                    <ListBox x:Name="TemplateList" Background="Transparent" BorderThickness="0"
                             ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource TemplateItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch"/>
                </DockPanel>

                <!-- Right: preview + description -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Rendered preview -->
                    <Border Grid.Row="0" CornerRadius="10" ClipToBounds="True" MinHeight="188"
                            BorderBrush="#2C2C33" BorderThickness="1">
                        <Grid>
                            <!-- fallback backdrop when a template ships no preview -->
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#242034" Offset="0"/>
                                        <GradientStop Color="#15141C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding HasNoPreview, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE809;" FontFamily="Segoe MDL2 Assets" FontSize="44"
                                           Foreground="#5A5273" HorizontalAlignment="Center"/>
                                <TextBlock Text="No preview available" Foreground="#5A5A63" FontSize="11.5"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"
                                   Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Border>

                    <!-- Name + description -->
                    <StackPanel Grid.Row="1" Margin="2,14,0,0">
                        <TextBlock Text="{Binding SelectedName}" Foreground="#F5F5F7" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedDescription}" Foreground="#93939B" FontSize="12.5"
                                   TextWrapping="Wrap" LineHeight="18" Margin="0,7,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Bottom: name / location / actions -->
            <Border Grid.Row="1" Background="#1C1C20" CornerRadius="0,0,12,12" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrushDark}" Padding="18,14,18,14" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Text="Project Name" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="ProjectNameTextBox" Style="{StaticResource DarkTextBox}"
                                 Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Text="Location" Style="{StaticResource LabelText}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocationTextBox" Style="{StaticResource DarkTextBox}"
                                     Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Style="{StaticResource IconButton}" Content="&#xE838;"
                                    Margin="8,0,0,0" Click="BrowseButton_Pressed" ToolTip="Choose a folder"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Cancel" Click="ExitButton_Pressed" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,0" IsCancel="True"/>
                        <Button Content="Create Project" Click="OpenButton_Pressed" Style="{StaticResource PrimaryButton}" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
