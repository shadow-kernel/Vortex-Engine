<Window x:Class="Editor.Project.Projection.ProjectBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Editor.Project.Projection"
        mc:Ignorable="d"
        Background="Transparent"
        Icon="{DynamicResource AppIcon}"
        Title="Project Browser - Vortex Engine" Height="740" Width="900"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Assets/Images/ImageResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="TabToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Foreground" Value="#CCFFFFFF"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="BackgroundBorder" Background="Transparent" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="Underline" Background="#2B7CEB" Height="3" VerticalAlignment="Bottom" Margin="10,0,10,-1" Opacity="0" CornerRadius="3"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#10FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#18FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#14FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#80FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TitleBarButton" TargetType="Button">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#E9E9ED"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#33333A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#44444C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid" MouseDown="RootGrid_OnMouseDown" Background="Transparent">
        <Border Background="#1A1A1C" CornerRadius="14" Padding="0" SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.45" BlurRadius="18" ShadowDepth="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" Background="#212124" MouseDown="RootGrid_OnMouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Image Source="{DynamicResource AppIcon}" Width="22" Height="22" Margin="0,0,8,0"/>
                        <TextBlock Text="Project Browser - Vortex Engine" VerticalAlignment="Center" Foreground="#E5FFFFFF" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Button Style="{StaticResource TitleBarButton}" Width="48" FontSize="16" Content="-" Click="MinimizeButton_OnClick"/>
                        <Button Style="{StaticResource TitleBarButton}" Content="X" Click="CloseButton_OnClick" Background="#33333A" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Header -->
                <Grid Grid.Row="1" Margin="80,-10,80,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="{DynamicResource AppIcon}" Width="40" Height="40" HorizontalAlignment="Left" Grid.Column="0"/>

                    <Border Grid.Column="1" Width="1" Height="40" Background="White" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               Text="Project Browser - Vortex Engine"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="White"/>
                </Grid>

                <Border Grid.Row="2"
                        Height="1"
                        VerticalAlignment="Center"
                        Margin="40,0,40,0"
                        Background="White"/>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,8">
                    <ToggleButton Content="Create New Project" Width="170" Height="44" Margin="0,0,12,0"
                            x:Name="createProjectButton" Click="OnToggleButtonClick" Style="{StaticResource TabToggleButtonStyle}"/>
                    <ToggleButton Content="Open Existing Project" Width="170" Height="44" Margin="0,0,0,0"
                            x:Name="openProjectButton" Click="OnToggleButtonClick" Style="{StaticResource TabToggleButtonStyle}"/>
                </StackPanel>

                <Grid Grid.Row="4" Margin="40,0,40,20" x:Name="browserContent">
                    <local:NewProjectView x:Name="newProjectView" Visibility="Collapsed" />
                    <local:OpenProjectView x:Name="openProjectView" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
