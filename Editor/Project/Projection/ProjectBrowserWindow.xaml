<Window x:Class="Editor.Project.Projection.ProjectBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Editor.Project.Projection"
        mc:Ignorable="d"
        Background="Transparent"
        Icon="pack://application:,,,/Logo.ico"
        Title="Project Browser - Vortex Engine" Height="800" Width="950"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Assets/Images/ImageResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- macOS-style traffic light (matches the editor shell) -->
            <Style x:Key="TrafficLight" TargetType="Button">
                <Setter Property="Width" Value="13"/>
                <Setter Property="Height" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <Ellipse x:Name="dot" Fill="{TemplateBinding Background}"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="dot" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Segmented pill tab (indigo accent) -->
            <Style x:Key="TabToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Foreground" Value="#9A9AA1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13.5"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="BackgroundBorder" Background="Transparent" CornerRadius="9">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#22FFFFFF"/>
                                    <Setter Property="Foreground" Value="#E9E9ED"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#6C5CE7"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#80FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid" MouseDown="RootGrid_OnMouseDown" Background="Transparent">
        <Border Background="#161618" CornerRadius="14" Padding="0" SnapsToDevicePixels="True"
                BorderBrush="#2C2C32" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="22" ShadowDepth="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Title bar: traffic lights + title -->
                <Grid Grid.Row="0" Background="#1A1A1C" MouseDown="TitleBar_OnMouseDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Button Style="{StaticResource TrafficLight}" Background="#FF5F57" ToolTip="Close" Click="CloseButton_OnClick"/>
                        <Button Style="{StaticResource TrafficLight}" Background="#FEBC2E" ToolTip="Minimize" Margin="8,0,0,0" Click="MinimizeButton_OnClick"/>
                        <Ellipse Width="13" Height="13" Fill="#2D2D33" Margin="8,0,0,0"/>
                        <Image Source="{DynamicResource AppIcon}" Width="18" Height="18" Margin="16,0,8,0"/>
                        <TextBlock Text="Project Browser — Vortex Engine" VerticalAlignment="Center"
                                   Foreground="#C8C8CE" FontSize="12.5" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <!-- Hero header -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,28,0,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="{DynamicResource AppIcon}" Width="34" Height="34" VerticalAlignment="Center"/>
                        <TextBlock Text="Vortex Engine" FontSize="24" FontWeight="Bold"
                                   Foreground="#F5F5F7" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Open an existing project or create a new one"
                               Foreground="#73737A" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Segmented tabs -->
                <Border Grid.Row="2" Background="#1B1B1E" BorderBrush="#2C2C32" BorderThickness="1"
                        CornerRadius="11" HorizontalAlignment="Center" Margin="0,18,0,6" Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton Content="Create New Project" Width="172" Height="38" Margin="0,0,4,0"
                                x:Name="createProjectButton" Click="OnToggleButtonClick" Style="{StaticResource TabToggleButtonStyle}"/>
                        <ToggleButton Content="Open Existing Project" Width="172" Height="38"
                                x:Name="openProjectButton" Click="OnToggleButtonClick" Style="{StaticResource TabToggleButtonStyle}"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="3" Margin="40,10,40,24" x:Name="browserContent">
                    <local:NewProjectView x:Name="newProjectView" Visibility="Collapsed" />
                    <local:OpenProjectView x:Name="openProjectView" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
