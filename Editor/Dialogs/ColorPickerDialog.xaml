<Window x:Class="Editor.Dialogs.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Picker" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#FF161618" ResizeMode="NoResize">
    
    <Window.Resources>
        <SolidColorBrush x:Key="TextCol" Color="#FFF1F1F1"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF9D9D9D"/>
        <SolidColorBrush x:Key="BorderCol" Color="#FF35353C"/>
        <SolidColorBrush x:Key="AccentCol" Color="#FF6C5CE7"/>
        <SolidColorBrush x:Key="ButtonBg" Color="#FF35353C"/>
        
        <Style x:Key="SimpleButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextCol}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SimpleButton}">
            <Setter Property="Background" Value="{StaticResource AccentCol}"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Color Area -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            
            <!-- Saturation/Value Square -->
            <Border x:Name="ColorSquare" Grid.Column="0" CornerRadius="4" ClipToBounds="True"
                    MouseLeftButtonDown="ColorSquare_MouseDown" MouseMove="ColorSquare_MouseMove"
                    MouseLeftButtonUp="ColorSquare_MouseUp">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop x:Name="HueColor" Color="Red" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border CornerRadius="4">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="Black" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Canvas>
                        <Ellipse x:Name="ColorSelector" Width="16" Height="16" 
                                 Stroke="White" StrokeThickness="2" Fill="Transparent"
                                 Canvas.Left="0" Canvas.Top="0" IsHitTestVisible="False">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                </Border>
            </Border>
            
            <!-- Hue Slider -->
            <Border Grid.Column="1" Margin="8,0,0,0" CornerRadius="4" ClipToBounds="True"
                    MouseLeftButtonDown="HueSlider_MouseDown" MouseMove="HueSlider_MouseMove"
                    MouseLeftButtonUp="HueSlider_MouseUp">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFF0000" Offset="0.000"/>
                        <GradientStop Color="#FFFFFF00" Offset="0.167"/>
                        <GradientStop Color="#FF00FF00" Offset="0.333"/>
                        <GradientStop Color="#FF00FFFF" Offset="0.500"/>
                        <GradientStop Color="#FF0000FF" Offset="0.667"/>
                        <GradientStop Color="#FFFF00FF" Offset="0.833"/>
                        <GradientStop Color="#FFFF0000" Offset="1.000"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Canvas>
                    <Border x:Name="HueSelector" Width="30" Height="6" 
                            Background="Transparent" BorderBrush="White" BorderThickness="2"
                            CornerRadius="2" Canvas.Top="0" IsHitTestVisible="False">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                </Canvas>
            </Border>
        </Grid>
        
        <!-- Preview and Values -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Color Preview -->
            <Border Grid.Column="0" x:Name="ColorPreview" CornerRadius="4" 
                    BorderBrush="{StaticResource BorderCol}" BorderThickness="1"/>
            
            <!-- RGB Values -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Text="R" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <Slider Grid.Row="0" Grid.Column="1" x:Name="RedSlider" Minimum="0" Maximum="255" 
                        VerticalAlignment="Center" ValueChanged="RgbSlider_ValueChanged"/>
                <TextBox Grid.Row="0" Grid.Column="2" x:Name="RedValue" Text="255" 
                         Background="#FF35353C" Foreground="{StaticResource TextCol}" 
                         BorderThickness="0" TextAlignment="Center" VerticalAlignment="Center"
                         TextChanged="RgbTextBox_TextChanged"/>
                
                <TextBlock Grid.Row="1" Text="G" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,4"/>
                <Slider Grid.Row="1" Grid.Column="1" x:Name="GreenSlider" Minimum="0" Maximum="255" 
                        VerticalAlignment="Center" Margin="0,4" ValueChanged="RgbSlider_ValueChanged"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="GreenValue" Text="255" 
                         Background="#FF35353C" Foreground="{StaticResource TextCol}" 
                         BorderThickness="0" TextAlignment="Center" VerticalAlignment="Center" Margin="0,4"
                         TextChanged="RgbTextBox_TextChanged"/>
                
                <TextBlock Grid.Row="2" Text="B" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <Slider Grid.Row="2" Grid.Column="1" x:Name="BlueSlider" Minimum="0" Maximum="255" 
                        VerticalAlignment="Center" ValueChanged="RgbSlider_ValueChanged"/>
                <TextBox Grid.Row="2" Grid.Column="2" x:Name="BlueValue" Text="255" 
                         Background="#FF35353C" Foreground="{StaticResource TextCol}" 
                         BorderThickness="0" TextAlignment="Center" VerticalAlignment="Center"
                         TextChanged="RgbTextBox_TextChanged"/>
            </Grid>
        </Grid>
        
        <!-- Hex and Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="Hex:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="HexValue" Text="#FFFFFF" Margin="8,0,16,0"
                     Background="#FF35353C" Foreground="{StaticResource TextCol}" 
                     BorderThickness="0" Padding="8,4" VerticalAlignment="Center"
                     TextChanged="HexValue_TextChanged"/>
            
            <Button Grid.Column="2" Content="OK" Click="OK_Click" Width="80" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButton}"/>
            <Button Grid.Column="3" Content="Cancel" Click="Cancel_Click" Width="80"
                    Style="{StaticResource SimpleButton}"/>
        </Grid>
    </Grid>
</Window>
