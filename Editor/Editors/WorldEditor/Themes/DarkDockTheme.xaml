<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
                    xmlns:avalonDockControls="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
                    xmlns:avalonDockConverters="clr-namespace:AvalonDock.Converters;assembly=AvalonDock">

    <Color x:Key="BackgroundColor">#1A1A1C</Color>
    <Color x:Key="PanelColor">#212124</Color>
    <Color x:Key="HeaderColor">#28282C</Color>
    <Color x:Key="BorderColor">#33333A</Color>
    <Color x:Key="AccentColor">#3FA9F5</Color>
    <Color x:Key="TextColor">#E9E9ED</Color>
    <Color x:Key="TextDimColor">#9A9AA1</Color>
    <Color x:Key="HoverColor">#33333A</Color>
    <Color x:Key="SelectedColor">#2C2C32</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}"/>

    <avalonDockConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <!-- Disable Focus Visual Style globally for dock elements -->
    <Style x:Key="NoFocusVisualStyle">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Global TabItem Style to remove focus borders -->
    <Style TargetType="{x:Type TabItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="Border" Background="{StaticResource HeaderBrush}" 
                            BorderBrush="Transparent" BorderThickness="0" 
                            Padding="10,6" Margin="0,0,1,0" SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource PanelBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="Border" Property="BorderThickness" Value="0,2,0,0"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Global Control style to disable focus visual -->
    <Style x:Key="NoFocusBorderStyle" TargetType="{x:Type Control}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- Button Style for Dock Pane -->
    <Style x:Key="DockPaneButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="2" Padding="2" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Anchorable Pane Title (Header above content) -->
    <Style TargetType="{x:Type avalonDockControls:AnchorablePaneTitle}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avalonDockControls:AnchorablePaneTitle}">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12,12,0,0" Margin="5,5,5,0" Padding="14,9" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Path=Model.Title, RelativeSource={RelativeSource TemplatedParent}}" Foreground="{StaticResource TextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <!-- Panels are fixed (CanClose/CanAutoHide=False); hide the pin/close
                                 buttons for the clean Aurora header look. PARTs stay in the tree. -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed">
                                <Button x:Name="PART_AutoHidePin" Style="{StaticResource DockPaneButtonStyle}" Content="&#xE718;" ToolTip="Auto Hide"/>
                                <Button x:Name="PART_HidePin" Style="{StaticResource DockPaneButtonStyle}" Content="&#xE711;" ToolTip="Close" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Anchorable Tab Item (Explorer, Console tabs) -->
    <Style TargetType="{x:Type avalonDockControls:LayoutAnchorableTabItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avalonDockControls:LayoutAnchorableTabItem}">
                    <Border x:Name="Border" 
                            Background="{StaticResource HeaderBrush}" 
                            BorderBrush="Transparent" 
                            BorderThickness="0" 
                            Padding="10,6" 
                            Margin="0,0,1,0"
                            Cursor="Hand"
                            SnapsToDevicePixels="True">
                        <TextBlock x:Name="Title" 
                                   Text="{Binding Path=Model.Title, RelativeSource={RelativeSource TemplatedParent}}" 
                                   Foreground="{StaticResource TextDimBrush}" 
                                   FontSize="11" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource PanelBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                            <Setter TargetName="Border" Property="BorderThickness" Value="0,2,0,0"/>
                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter TargetName="Title" Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSelected}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </MultiDataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBrush}"/>
                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Document Tab Item -->
    <Style TargetType="{x:Type avalonDockControls:LayoutDocumentTabItem}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avalonDockControls:LayoutDocumentTabItem}">
                    <Border x:Name="Border" 
                            Background="{StaticResource HeaderBrush}" 
                            BorderBrush="Transparent" 
                            BorderThickness="0" 
                            Padding="10,6" 
                            Margin="0,0,1,0"
                            Cursor="Hand"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Title" Grid.Column="0" Text="{Binding Path=Model.Title, RelativeSource={RelativeSource TemplatedParent}}" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                            <Button x:Name="PART_CloseButton" Grid.Column="1" Style="{StaticResource DockPaneButtonStyle}" Content="&#xE711;" Width="16" Height="16" Margin="6,0,0,0" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <!-- Active document: blend into the dark pane card; indicate via
                                 brighter bold text, not a bright accent box (was #3FA9F5). -->
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource PanelBrush}"/>
                            <Setter TargetName="Border" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter TargetName="Title" Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBrush}"/>
                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Anchorable Pane Control — property-only (NO custom Template) so AvalonDock's default
         template keeps hosting the panel content + tabs correctly, while BorderThickness=0
         removes the light GenericTheme border that was leaking at every pane edge. -->
    <Style x:Key="DarkAnchorablePaneStyle" TargetType="{x:Type avalonDockControls:LayoutAnchorablePaneControl}">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="TabStripPlacement" Value="Bottom"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- Document Pane Control — property-only (see Anchorable note above). -->
    <Style x:Key="DarkDocumentPaneStyle" TargetType="{x:Type avalonDockControls:LayoutDocumentPaneControl}">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="TabStripPlacement" Value="Top"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- Grid Resizer (the splitter between panes). The default template draws a light 3D
         grip (gray/white lines) — re-template to a plain dark bar so panes abut cleanly.
         Still fully draggable (drag logic is in the control, not the template). -->
    <Style TargetType="{x:Type avalonDockControls:LayoutGridResizerControl}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avalonDockControls:LayoutGridResizerControl}">
                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Auto Hide Anchor -->
    <Style TargetType="{x:Type avalonDockControls:LayoutAnchorControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avalonDockControls:LayoutAnchorControl}">
                    <Border x:Name="Border" Background="{StaticResource HeaderBrush}" BorderBrush="Transparent" BorderThickness="0" Padding="8,4" Cursor="Hand" SnapsToDevicePixels="True">
                        <TextBlock x:Name="Title" Text="{Binding Path=Model.Title, RelativeSource={RelativeSource TemplatedParent}}" Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBrush}"/>
                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Floating Windows (torn-off panels) — dark border, not the bright accent which
         read as a light/white frame. -->
    <Style TargetType="{x:Type avalonDockControls:LayoutAnchorableFloatingWindowControl}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <Style TargetType="{x:Type avalonDockControls:LayoutDocumentFloatingWindowControl}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- Auto-hide flyout host (slides out when a CanAutoHide panel is clicked).
         Un-templated by default => AvalonDock's light generic theme leaks white here. -->
    <Style TargetType="{x:Type avalonDockControls:LayoutAutoHideWindowControl}">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    </Style>

    <!-- Drag/drop overlay window shown while docking a panel — keep it dark, not white. -->
    <Style TargetType="{x:Type avalonDockControls:OverlayWindow}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
    </Style>

    <!-- Dropdown Button for tabs overflow -->
    <Style TargetType="{x:Type avalonDockControls:DropDownButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- Navigator Window -->
    <Style TargetType="{x:Type avalonDockControls:NavigatorWindow}">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <!-- Docking Manager -->
    <Style TargetType="{x:Type avalonDock:DockingManager}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
    </Style>

    <!-- Resize splitter between panes — plain dark, no light grip/border. AvalonDock applies
         this via DockingManager.GridSplitterVertical/HorizontalStyle (set in WorldEditorView),
         which overrides the white GenericTheme splitter that was leaking at every pane edge. -->
    <Style x:Key="DarkResizeGrip" TargetType="{x:Type avalonDockControls:LayoutGridResizerControl}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avalonDockControls:LayoutGridResizerControl}">
                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Container controls: AvalonDock's GenericTheme gives these a default (white) border,
         which showed as a thin white hairline down the left edge of the document/viewport
         pane. Force them dark and border-less so only our styled panes/cards are visible. -->
    <!-- Re-template the document content host: AvalonDock's generic template wraps the
         content in a Border with a default (white) BorderBrush, which a plain BorderThickness
         setter cannot override. A border-less ContentPresenter kills the white hairline while
         still showing the document content (Model.Content = the viewport). -->
    <Style TargetType="{x:Type avalonDockControls:LayoutDocumentControl}">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avalonDockControls:LayoutDocumentControl}">
                    <Border Background="{TemplateBinding Background}" BorderThickness="0" SnapsToDevicePixels="True">
                        <ContentPresenter Content="{Binding Model.Content, RelativeSource={RelativeSource TemplatedParent}}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type avalonDockControls:LayoutDocumentPaneGroupControl}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
    </Style>
    <Style TargetType="{x:Type avalonDockControls:LayoutAnchorablePaneGroupControl}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
    </Style>
    <Style TargetType="{x:Type avalonDockControls:LayoutPanelControl}">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
    </Style>

</ResourceDictionary>