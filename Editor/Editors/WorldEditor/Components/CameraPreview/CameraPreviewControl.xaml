<UserControl x:Class="Editor.Editors.WorldEditor.Components.CameraPreview.CameraPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="180" d:DesignWidth="320"
             Background="Transparent">
    
    <Border Background="#FF1E1E1E" BorderBrush="#FF3C3C3C" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#FF2D2D30" CornerRadius="4,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock x:Name="CameraIcon" Text="&#xE722;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="12" Foreground="#9B59B6" 
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="CameraNameText" Text="Camera Preview" FontSize="11" 
                                   Foreground="#FFC5C5C5" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,4,0">
                        <!-- Switch to this camera button -->
                        <Button x:Name="SwitchToButton" ToolTip="Switch viewport to this camera"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand" Margin="0,0,2,0"
                                Click="SwitchTo_Click">
                            <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="12" Foreground="#FF808080"/>
                        </Button>
                        
                        <!-- Close button -->
                        <Button x:Name="CloseButton" ToolTip="Close preview"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand"
                                Click="Close_Click">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="12" Foreground="#FF808080"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Preview viewport (placeholder - would be a D3D surface in production) -->
            <Border Grid.Row="1" Background="#FF0A0A0A" Margin="2">
                <Grid>
                    <!-- Preview content would go here -->
                    <TextBlock x:Name="PreviewPlaceholder" 
                               Text="Camera Preview" 
                               Foreground="#FF404040"
                               FontSize="12"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                    
                    <!-- Camera info overlay -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="4">
                        <TextBlock x:Name="FovText" Text="FOV: 60" 
                                   Foreground="#80FFFFFF" FontSize="9"/>
                        <TextBlock x:Name="ClipText" Text="Clip: 0.1 - 1000" 
                                   Foreground="#80FFFFFF" FontSize="9"/>
                    </StackPanel>
                    
                    <!-- Camera type indicator -->
                    <Border x:Name="TypeBadge" 
                            VerticalAlignment="Top" HorizontalAlignment="Right" 
                            Margin="4" Padding="4,2" CornerRadius="2"
                            Background="#809B59B6">
                        <TextBlock x:Name="TypeText" Text="MAIN" 
                                   Foreground="White" FontSize="8" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
