<UserControl x:Class="Editor.Editors.WorldEditor.Components.HeaderBar.HeaderBarView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
mc:Ignorable="d" 
d:DesignHeight="64" d:DesignWidth="1200">

<UserControl.Resources>
    <Style x:Key="MenuButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#C5C5C5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#3C3C3C"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#505050"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#909090"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#3C3C3C"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#505050"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Foreground" Value="#4EC9B0"/>
    </Style>

    <Style x:Key="PauseButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Foreground" Value="#DCDCAA"/>
    </Style>

    <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Foreground" Value="#F14C4C"/>
    </Style>

    <Style x:Key="BuildButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Foreground" Value="#569CD6"/>
    </Style>

    <Style x:Key="ToolbarSeparator" TargetType="Rectangle">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Fill" Value="#404040"/>
        <Setter Property="Margin" Value="6,4"/>
    </Style>

    <!-- Dark Theme Menu Styles -->
    <Style x:Key="DarkMenuStyle" TargetType="Menu">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#C5C5C5"/>
    </Style>

    <!-- Dark MenuItem Style for all menu items -->
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#C5C5C5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="Transparent" 
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="20" SharedSizeGroup="MenuItemIconColumnGroup"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemShortcutColumnGroup"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="Icon" Grid.Column="0" ContentSource="Icon" 
                                              VerticalAlignment="Center" HorizontalAlignment="Center"
                                              Width="16" Height="16" Margin="0,0,4,0"/>
                            <ContentPresenter x:Name="HeaderHost" Grid.Column="1" ContentSource="Header" 
                                              RecognizesAccessKey="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="InputGestureText" Grid.Column="2" 
                                       Text="{TemplateBinding InputGestureText}" 
                                       Margin="24,0,8,0" Foreground="#808080" VerticalAlignment="Center"/>
                            <Path x:Name="SubMenuArrow" Grid.Column="3" 
                                  Data="M 0 0 L 4 4 L 0 8 Z" Fill="#808080" 
                                  VerticalAlignment="Center" Margin="4,0,0,0"
                                  Visibility="Collapsed"/>
                            <Popup x:Name="PART_Popup" 
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right" 
                                   AllowsTransparency="True" 
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   HorizontalOffset="-2">
                                <Border Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="1" Padding="0,2">
                                    <Grid IsSharedSizeScope="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                            <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="0"/>
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Role" Value="TopLevelItem">
                            <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuItem">
                            <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#656565"/>
                        </Trigger>
                        <Trigger Property="IsCheckable" Value="True">
                            <Setter TargetName="Icon" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Icon" Property="Content">
                                <Setter.Value>
                                    <TextBlock Text="?" Foreground="#4EC9B0" FontWeight="Bold" FontSize="12"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Separator}">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="#404040"/>
        <Setter Property="Margin" Value="28,4,8,4"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}" SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="#2D2D2D"/>
        <Setter Property="Foreground" Value="#C5C5C5"/>
        <Setter Property="BorderBrush" Value="#3C3C3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="0,2">
                        <Grid IsSharedSizeScope="True">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu Control Style -->
    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#C5C5C5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Menu}">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="Transparent" 
                            BorderThickness="0"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" 
                                    Orientation="Horizontal" 
                                    ClipToBounds="True"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</UserControl.Resources>

<Grid Background="#1E1E1E">
    <Grid.RowDefinitions>
        <RowDefinition Height="28"/>
        <RowDefinition Height="32"/>
    </Grid.RowDefinitions>

    <!-- Row 0: Menu Bar -->
    <Grid Grid.Row="0" Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Menu Items -->
        <Menu Grid.Column="0" Background="#1E1E1E" Foreground="#C5C5C5" VerticalAlignment="Center" IsMainMenu="True">
            
            <!-- File Menu -->
            <MenuItem Header="_File">
                <MenuItem Header="Open _Other Project..." Click="OpenOtherProject_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Close Project" Click="CloseProject_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Build _Settings..." Click="BuildSettings_Click"/>
                <MenuItem Header="_Build" InputGestureText="F5" Click="Build_Click"/>
                <MenuItem Header="Build and _Run" InputGestureText="F6" Click="BuildAndRun_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" InputGestureText="Alt+F4" Click="Exit_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            
            <!-- Edit Menu -->
            <MenuItem Header="_Edit">
                <MenuItem x:Name="UndoMenuItem" Header="_Undo" InputGestureText="Ctrl+Z" Click="Undo_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="RedoMenuItem" Header="_Redo" InputGestureText="Ctrl+Y" Click="Redo_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Cu_t" InputGestureText="Ctrl+X" Click="Cut_Click"/>
                <MenuItem Header="_Copy" InputGestureText="Ctrl+C" Click="Copy_Click"/>
                <MenuItem Header="_Paste" InputGestureText="Ctrl+V" Click="Paste_Click"/>
                <MenuItem Header="_Delete" InputGestureText="Del" Click="Delete_Click"/>
                <MenuItem Header="D_uplicate" InputGestureText="Ctrl+D" Click="Duplicate_Click"/>
                <Separator/>
                <MenuItem Header="Select _All" InputGestureText="Ctrl+A"/>
                <MenuItem Header="_Find..." InputGestureText="Ctrl+F"/>
            </MenuItem>
            
            
            <!-- View Menu -->
            <MenuItem Header="_View">
                <MenuItem x:Name="ToggleGridMenuItem" Header="_Toggle Grid" InputGestureText="G" 
                          IsCheckable="True" IsChecked="True" Click="ToggleGrid_Click"/>
                <MenuItem x:Name="SnapToGridMenuItem" Header="_Snap to Grid" 
                          IsCheckable="True" IsChecked="False" Click="SnapToGrid_Click"/>
                <MenuItem x:Name="ToggleGizmosMenuItem" Header="Toggle _Gizmos" 
                          IsCheckable="True" IsChecked="True" Click="ToggleGizmos_Click"/>
                <Separator/>
                <MenuItem Header="_Zoom In" InputGestureText="Ctrl++"/>
                <MenuItem Header="Zoom _Out" InputGestureText="Ctrl+-"/>
                <MenuItem Header="_Reset Zoom"/>
            </MenuItem>
            
            <!-- Assets Menu -->
            <MenuItem Header="_Assets">
                <MenuItem Header="_Import Asset..." Click="ImportAsset_Click"/>
                <MenuItem Header="_Export Asset..."/>
                <Separator/>
                <MenuItem Header="Create _Material"/>
                <MenuItem Header="Create _Shader"/>
                <MenuItem Header="Create S_cript" Click="CreateScript_Click"/>
                <Separator/>
                <MenuItem Header="Open C# Project in _Visual Studio" Click="OpenScriptsInVS_Click"/>
            </MenuItem>
            
            <!-- GameObject Menu -->
            <MenuItem Header="_GameObject">
                <MenuItem Header="Create _Empty" Click="CreateEmpty_Click"/>
                <MenuItem Header="Create _3D Object">
                    <MenuItem Header="_Cube" Click="CreateCube_Click"/>
                    <MenuItem Header="_Sphere" Click="CreateSphere_Click"/>
                    <MenuItem Header="_Capsule" Click="CreateCapsule_Click"/>
                    <MenuItem Header="C_ylinder" Click="CreateCylinder_Click"/>
                    <MenuItem Header="_Plane" Click="CreatePlane_Click"/>
                </MenuItem>
                <MenuItem Header="Create _2D Object">
                    <MenuItem Header="_Sprite"/>
                    <MenuItem Header="_Tilemap"/>
                </MenuItem>
                <MenuItem Header="Create _Light">
                    <MenuItem Header="_Directional Light" Click="CreateDirectionalLight_Click"/>
                    <MenuItem Header="_Point Light" Click="CreatePointLight_Click"/>
                    <MenuItem Header="_Spot Light" Click="CreateSpotLight_Click"/>
                </MenuItem>
                <MenuItem Header="Create _Camera" Click="CreateCamera_Click"/>
            </MenuItem>
            
            <!-- Component Menu -->
            <MenuItem Header="_Component">
                <MenuItem Header="Add _Component..."/>
                <Separator/>
                <MenuItem Header="_Physics">
                    <MenuItem Header="_Rigidbody" Click="AddRigidbody_Click"/>
                    <MenuItem Header="_Box Collider" Click="AddBoxCollider_Click"/>
                    <MenuItem Header="_Sphere Collider" Click="AddSphereCollider_Click"/>
                    <MenuItem Header="_Capsule Collider" Click="AddCapsuleCollider_Click"/>
                </MenuItem>
                <MenuItem Header="_Rendering">
                    <MenuItem Header="_Mesh Renderer" Click="AddMeshRenderer_Click"/>
                    <MenuItem Header="_Sprite Renderer"/>
                </MenuItem>
                <MenuItem Header="_Audio">
                    <MenuItem Header="Audio _Source" Click="AddAudioSource_Click"/>
                    <MenuItem Header="Audio _Listener"/>
                </MenuItem>
                <MenuItem Header="_Script">
                    <MenuItem Header="New _Script..." Click="AddScript_Click"/>
                </MenuItem>
            </MenuItem>
            
            <!-- Window Menu -->
            <MenuItem Header="_Window" x:Name="WindowMenu">
                <MenuItem x:Name="MenuSceneWindow" Header="_Scene" IsCheckable="True" IsChecked="True" Click="ToggleWindow_Click" Tag="Scene"/>
                <MenuItem x:Name="MenuProjectWindow" Header="_Project" IsCheckable="True" IsChecked="True" Click="ToggleWindow_Click" Tag="Project"/>
                <MenuItem x:Name="MenuExplorerWindow" Header="_Explorer" IsCheckable="True" IsChecked="True" Click="ToggleWindow_Click" Tag="Explorer"/>
                <MenuItem x:Name="MenuConsoleWindow" Header="_Console" IsCheckable="True" IsChecked="True" Click="ToggleWindow_Click" Tag="Console"/>
                <MenuItem x:Name="MenuHierarchyWindow" Header="_Hierarchy" IsCheckable="True" IsChecked="True" Click="ToggleWindow_Click" Tag="Hierarchy"/>
                <MenuItem x:Name="MenuInspectorWindow" Header="_Inspector" IsCheckable="True" IsChecked="True" Click="ToggleWindow_Click" Tag="Inspector"/>
                <Separator/>
                <MenuItem Header="_Reset Layout" Click="ResetLayout_Click"/>
            </MenuItem>
            
            <!-- Help Menu -->
            <MenuItem Header="_Help">
                <MenuItem Header="_Documentation" Click="Documentation_Click"/>
                <MenuItem Header="_API Reference"/>
                <Separator/>
                <MenuItem Header="_Check for Updates..."/>
                <MenuItem Header="_About Vortex Engine" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Right Side: Window Controls Placeholder -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0">
            <Button Content="&#xE713;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Settings"/>
        </StackPanel>
    </Grid>

    <!-- Row 1: Icon Toolbar -->
    <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0">
        <Grid Margin="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left Toolbar: File & Edit Operations -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- File Operations -->
                <Button Content="&#xE8E5;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="New Scene (Ctrl+N)"/>
                <Button Content="&#xE8E6;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open Scene (Ctrl+O)"/>
                <Button Content="&#xE74E;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save Scene (Ctrl+S)"/>
                <Button Content="&#xE792;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save All (Ctrl+Shift+S)"/>
                    
                <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    
                <!-- Edit Operations -->
                <Button Content="&#xE7A7;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Undo (Ctrl+Z)"/>
                <Button Content="&#xE7A6;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Redo (Ctrl+Y)"/>
                    
                <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    
                <!-- Clipboard -->
                <Button Content="&#xE8C8;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Cut (Ctrl+X)"/>
                <Button Content="&#xE8C9;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Copy (Ctrl+C)"/>
                <Button Content="&#xE77F;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Paste (Ctrl+V)"/>
                <Button Content="&#xE74D;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Delete (Del)"/>
                <Button Content="&#xE8C6;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Duplicate (Ctrl+D)"/>
                    
                <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    
                <!-- Transform Tools -->
                <Button x:Name="MoveToolButton" Content="&#xE759;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Move Tool (W)" Click="MoveTool_Click"/>
                <Button x:Name="RotateToolButton" Content="&#xE7AD;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Rotate Tool (E)" Click="RotateTool_Click"/>
                <Button x:Name="ScaleToolButton" Content="&#xE740;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Scale Tool (R)" Click="ScaleTool_Click"/>
                <Button Content="&#xE73F;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Rect Tool (T)"/>
                    
                <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    
                <!-- View Options -->
                <Button x:Name="ToggleGridButton" Content="&#xE8B3;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Toggle Grid (G)" Click="ToggleGridButton_Click"/>
                <Button x:Name="SnapToGridButton" Content="&#xE81E;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Snap to Grid" Click="SnapToGridButton_Click"/>
                <Button x:Name="ToggleGizmosButton" Content="&#xE7B3;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Toggle Gizmos" Click="ToggleGizmosButton_Click"/>
            </StackPanel>

            <!-- Center Toolbar: Play Controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="PlayButton" Content="&#xE768;" Style="{StaticResource PlayButtonStyle}" 
                        ToolTip="Play (Ctrl+P)" Width="30" Height="28" Click="PlayButton_Click"/>
                <Button x:Name="PauseButton" Content="&#xE769;" Style="{StaticResource PauseButtonStyle}" 
                        ToolTip="Pause (Ctrl+Shift+P)" Width="30" Height="28" Margin="2,0" Click="PauseButton_Click"/>
                <Button Content="&#xE71A;" Style="{StaticResource ToolbarButtonStyle}" 
                        ToolTip="Step Frame" Width="30" Height="28" Margin="2,0"/>
                <Button x:Name="StopButton" Content="&#xE71E;" Style="{StaticResource StopButtonStyle}" 
                        ToolTip="Stop" Width="30" Height="28" Click="StopButton_Click"/>
            </StackPanel>

            <!-- Right Toolbar: Build & External Tools -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Build -->
                <Button Content="&#xE72C;" Style="{StaticResource BuildButtonStyle}" ToolTip="Build Project (F5)"/>
                <Button Content="&#xE756;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Build Settings"/>
                <Button Content="&#xE768;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Build and Run (F6)"/>
                    
                <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    
                <!-- External Tools -->
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open in Visual Studio (Ctrl+Shift+V)">
                    <TextBlock Text="VS" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"/>
                </Button>
                <Button Content="&#xE70F;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open Project Folder"/>
                <Button Content="&#xE756;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Package Manager"/>
                    
                <Rectangle Style="{StaticResource ToolbarSeparator}"/>
                    
                <!-- Layout & Settings -->
                <Button Content="&#xE946;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Layout"/>
                <Button Content="&#xE771;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Maximize Game View"/>
                <Button Content="&#xE7E8;" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Console"/>
            </StackPanel>
        </Grid>
    </Border>
</Grid>
</UserControl>
