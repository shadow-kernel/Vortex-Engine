<UserControl x:Class="Editor.Editors.WorldEditor.Components.FileExplorer.FileTreeView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         mc:Ignorable="d" 
         d:DesignHeight="200" d:DesignWidth="200">

<UserControl.Resources>
    <!-- MenuItem Style for Dark Theme -->
    <Style x:Key="DarkMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#E9E9ED"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" 
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" ContentSource="Icon" 
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1" ContentSource="Header" 
                                              Margin="4,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" 
                                       Foreground="#73737A" FontSize="10" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#33333A"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#73737A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Context Menu Style for Dark Theme -->
    <Style x:Key="DarkContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="Background" Value="#212124"/>
        <Setter Property="BorderBrush" Value="#33333A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator Style for Dark Theme -->
    <Style x:Key="DarkSeparatorStyle" TargetType="Separator">
        <Setter Property="Background" Value="#33333A"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="8,4"/>
    </Style>

    <!-- Context Menu -->
    <ContextMenu x:Key="FolderContextMenu" Style="{StaticResource DarkContextMenuStyle}">
        <MenuItem Header="New Folder" Click="OnNewFolderClick" Style="{StaticResource DarkMenuItemStyle}">
            <MenuItem.Icon>
                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" Foreground="#E6B422" FontSize="12"/>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="New Script" Click="OnNewScriptClick" Style="{StaticResource DarkMenuItemStyle}">
            <MenuItem.Icon>
                <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" Foreground="#9B59B6" FontSize="12"/>
            </MenuItem.Icon>
        </MenuItem>
        <Separator Style="{StaticResource DarkSeparatorStyle}"/>
        <MenuItem Header="Rename" Click="OnRenameClick" InputGestureText="F2" Style="{StaticResource DarkMenuItemStyle}">
            <MenuItem.Icon>
                <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" Foreground="#9A9AA1" FontSize="12"/>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="Delete" Click="OnDeleteClick" InputGestureText="Del" Style="{StaticResource DarkMenuItemStyle}">
            <MenuItem.Icon>
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#E74C3C" FontSize="12"/>
            </MenuItem.Icon>
        </MenuItem>
        <Separator Style="{StaticResource DarkSeparatorStyle}"/>
        <MenuItem Header="Show in Explorer" Click="OnShowInExplorerClick" Style="{StaticResource DarkMenuItemStyle}">
            <MenuItem.Icon>
                <TextBlock Text="&#xEC50;" FontFamily="Segoe MDL2 Assets" Foreground="#3FA9F5" FontSize="12"/>
            </MenuItem.Icon>
        </MenuItem>
    </ContextMenu>

    <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="#E9E9ED"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        <Setter Property="ContextMenu" Value="{StaticResource FolderContextMenu}"/>
        <Setter Property="AllowDrop" Value="True"/>
        <Setter Property="ItemsSource" Value="{Binding Children}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" MinHeight="28"
                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander" Grid.Column="0"
                                              IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press" Width="16" Height="16" Focusable="False">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Padding="4">
                                                <Path x:Name="Arrow" Data="M0,0 L4,4 L0,8 Z"
                                                      Fill="#73737A" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0" CenterX="2" CenterY="4"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" CenterX="2" CenterY="4"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Arrow" Property="Fill" Value="#E9E9ED"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <TextBlock x:Name="FolderIcon" Grid.Column="1" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Foreground="#E6B422" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <TextBlock x:Name="HeaderText" Grid.Column="2" Text="{Binding Name}"
                                           VerticalAlignment="Center" Visibility="Visible"/>
                                <TextBox x:Name="RenameBox" Grid.Column="2" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center" Visibility="Collapsed"
                                         Background="#161618" Foreground="#E9E9ED" BorderBrush="#6C5CE7"
                                         BorderThickness="1" Padding="4,1"/>
                            </Grid>
                        </Border>
                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="14,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <!-- Expander nur anzeigen wenn der Ordner Unterordner hat -->
                        <DataTrigger Binding="{Binding HasSubDirectories}" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                        </DataTrigger>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="FolderIcon" Property="Text" Value="&#xE838;"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2C2C32"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="#FFFFFF"/>
                            <Setter TargetName="FolderIcon" Property="Foreground" Value="#6C5CE7"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#28282C"/>
                        </MultiTrigger>
                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="RenameBox" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnTreeViewItemMouseDown"/>
        <EventSetter Event="Drop" Handler="OnTreeViewItemDrop"/>
        <EventSetter Event="DragOver" Handler="OnTreeViewItemDragOver"/>
        <EventSetter Event="Expanded" Handler="OnTreeViewItemExpanded"/>
    </Style>
</UserControl.Resources>

<Border Background="#212124">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Section Header (collapsed: the AvalonDock pane title "File System" already labels
             this panel — the internal header was a redundant second title). -->
        <Border Grid.Row="0" Background="#212124" Padding="14,12,12,8"
                Visibility="Collapsed"
                BorderBrush="#2C2C32" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xEC50;" FontFamily="Segoe MDL2 Assets"
                           FontSize="13" Foreground="#9A9AA1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" Text="File System"
                           FontFamily="Segoe UI Variable Text, Segoe UI" FontWeight="SemiBold"
                           FontSize="12" Foreground="#E9E9ED" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Background="Transparent" Foreground="#9A9AA1" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" ToolTip="Refresh" Click="OnRefreshClick"/>
                    <Button x:Name="CollapseAllButton" Content="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Background="Transparent" Foreground="#9A9AA1" BorderThickness="0"
                            Padding="6,4" Cursor="Hand" ToolTip="Collapse All" Click="OnCollapseAllClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tree View -->
        <TreeView x:Name="FolderTree" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="6,8,6,8"
                  ItemsSource="{Binding Children}" ItemContainerStyle="{StaticResource TreeViewItemStyle}"
                  SelectedItemChanged="OnSelectedFolderChanged" AllowDrop="True"
                  VirtualizingStackPanel.IsVirtualizing="False">
        </TreeView>

        <!-- Empty State -->
        <TextBlock x:Name="EmptyText" Grid.Row="1" Text="No project loaded"
                   Foreground="#73737A" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Border>
</UserControl>
