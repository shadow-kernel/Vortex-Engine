<UserControl x:Class="Editor.Editors.WorldEditor.Components.FileExplorer.FileExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="400">

    <UserControl.Resources>
        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3C3C3C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C5C5C5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" CornerRadius="4" Width="80">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#37373D"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3FA9F5"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#252526">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Breadcrumb Navigation -->
            <Border Grid.Row="0" Background="#1E1E1E" Padding="4,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                            Style="{StaticResource BreadcrumbButtonStyle}" ToolTip="Back"/>
                    <Button Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                            Style="{StaticResource BreadcrumbButtonStyle}" ToolTip="Forward" Margin="2,0"/>
                    <Button Content="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                            Style="{StaticResource BreadcrumbButtonStyle}" ToolTip="Up"/>
                    <Rectangle Width="1" Fill="#404040" Margin="6,4"/>
                    <Button Content="Assets" Style="{StaticResource BreadcrumbButtonStyle}"/>
                    <TextBlock Text="/" Foreground="#505050" VerticalAlignment="Center" Margin="2,0"/>
                    <Button Content="Models" Style="{StaticResource BreadcrumbButtonStyle}"/>
                    <Rectangle Width="1" Fill="#404040" Margin="6,4"/>
                    <Button Content="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                            Style="{StaticResource BreadcrumbButtonStyle}" ToolTip="Search"/>
                    <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                            Style="{StaticResource BreadcrumbButtonStyle}" ToolTip="New"/>
                </StackPanel>
            </Border>

            <!-- File Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ListBox Background="Transparent" BorderThickness="0" Padding="8">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <!-- Sample Folders -->
                    <ListBoxItem Style="{StaticResource FileItemStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                       Foreground="#E6B422" HorizontalAlignment="Center"/>
                            <TextBlock Text="Characters" Foreground="#C5C5C5" FontSize="10" 
                                       HorizontalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource FileItemStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                       Foreground="#E6B422" HorizontalAlignment="Center"/>
                            <TextBlock Text="Environment" Foreground="#C5C5C5" FontSize="10" 
                                       HorizontalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource FileItemStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                       Foreground="#E6B422" HorizontalAlignment="Center"/>
                            <TextBlock Text="Props" Foreground="#C5C5C5" FontSize="10" 
                                       HorizontalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </ListBoxItem>

                    <!-- Sample Files -->
                    <ListBoxItem Style="{StaticResource FileItemStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xF158;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                       Foreground="#4EC9B0" HorizontalAlignment="Center"/>
                            <TextBlock Text="Player.fbx" Foreground="#C5C5C5" FontSize="10" 
                                       HorizontalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource FileItemStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xF158;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                       Foreground="#4EC9B0" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cube.obj" Foreground="#C5C5C5" FontSize="10" 
                                       HorizontalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource FileItemStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                       Foreground="#9B59B6" HorizontalAlignment="Center"/>
                            <TextBlock Text="Wood.mat" Foreground="#C5C5C5" FontSize="10" 
                                       HorizontalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
