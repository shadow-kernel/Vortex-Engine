<UserControl x:Class="Editor.Editors.WorldEditor.Components.AssetBrowser.AssetBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             Background="#FF212124">
    
    <UserControl.Resources>
        <Style x:Key="AssetItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF33333A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF28282C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#FF28282C" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Asset Browser" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#FFE9E9ED" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ImportButton" Content="&#xE8B5;" FontFamily="Segoe MDL2 Assets"
                            Background="Transparent" BorderThickness="0" Foreground="#FF9A9AA1"
                            Padding="6" FontSize="14" ToolTip="Import Asset"
                            Click="ImportButton_Click" Margin="0,0,4,0"/>
                    <Button x:Name="RefreshButton" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                            Background="Transparent" BorderThickness="0" Foreground="#FF9A9AA1"
                            Padding="6" FontSize="14" ToolTip="Refresh"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Category Tabs -->
        <Border Grid.Row="1" Background="#FF1A1A1C" Padding="5">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="MeshesTab" Content="Meshes" GroupName="AssetType" 
                             IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}"
                             Background="#FF33333A" Foreground="#FFE9E9ED" 
                             Padding="12,6" Margin="2" BorderThickness="0"
                             Checked="AssetTypeTab_Checked"/>
                <RadioButton x:Name="ModelsTab" Content="Models" GroupName="AssetType"
                             Style="{StaticResource {x:Type ToggleButton}}"
                             Background="#FF33333A" Foreground="#FFE9E9ED" 
                             Padding="12,6" Margin="2" BorderThickness="0"
                             Checked="AssetTypeTab_Checked"/>
                <RadioButton x:Name="TexturesTab" Content="Textures" GroupName="AssetType"
                             Style="{StaticResource {x:Type ToggleButton}}"
                             Background="#FF33333A" Foreground="#FFE9E9ED" 
                             Padding="12,6" Margin="2" BorderThickness="0"
                             Checked="AssetTypeTab_Checked"/>
                <RadioButton x:Name="MaterialsTab" Content="Materials" GroupName="AssetType"
                             Style="{StaticResource {x:Type ToggleButton}}"
                             Background="#FF33333A" Foreground="#FFE9E9ED" 
                             Padding="12,6" Margin="2" BorderThickness="0"
                             Checked="AssetTypeTab_Checked"/>
            </StackPanel>
        </Border>
        
        <!-- Asset List -->
        <ListBox x:Name="AssetList" Grid.Row="2" 
                 Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource AssetItemStyle}"
                 SelectionChanged="AssetList_SelectionChanged"
                 MouseDoubleClick="AssetList_MouseDoubleClick">
            <ListBox.ContextMenu>
                <ContextMenu Background="#FF28282C" BorderBrush="#FF33333A">
                    <MenuItem Header="Add to Scene" Click="ContextMenu_AddToScene_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Foreground="#FF4EC9B0"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open in Asset Browser" Click="ContextMenu_OpenInBrowser_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" Foreground="#FF569CD6"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Delete" Click="ContextMenu_Delete_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#FFCE9178"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding IconCode}" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="16" Foreground="{Binding IconColor}" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#FFE9E9ED"/>
                            <TextBlock Text="{Binding TypeName}" FontSize="10" Foreground="#FF9A9AA1"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
