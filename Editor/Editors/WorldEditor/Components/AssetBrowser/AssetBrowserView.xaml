<UserControl x:Class="Editor.Editors.WorldEditor.Components.AssetBrowser.AssetBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400"
             Background="#FF212124">

    <UserControl.Resources>
        <!-- Asset thumbnail TILE -->
        <Style x:Key="AssetItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TileBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1.5"
                                CornerRadius="10"
                                Padding="6,8">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="#FF28282C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="#FF2C2C32"/>
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="#FF6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar icon button -->
        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FF9A9AA1"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF33333A"/>
                                <Setter Property="Foreground" Value="#FFE9E9ED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category pill (RadioButton) -->
        <Style x:Key="CategoryPill" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FF9A9AA1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Pill" Background="{TemplateBinding Background}"
                                BorderBrush="#FF33333A" BorderThickness="1"
                                CornerRadius="8" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#FF28282C"/>
                                <Setter Property="Foreground" Value="#FFE9E9ED"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#FF6C5CE7"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#FF6C5CE7"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FF212124" Padding="14,12,12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Redundant "Asset Browser" title removed; the AvalonDock pane title "Project"
                     already labels this panel. Import/Refresh buttons stay. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="&#xEC50;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="#FF9A9AA1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Asset Browser" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               Foreground="#FFE9E9ED" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ImportButton" Content="&#xE8B5;"
                            Style="{StaticResource ToolbarIconButton}"
                            ToolTip="Import Asset"
                            Click="ImportButton_Click" Margin="0,0,2,0"/>
                    <Button x:Name="RefreshButton" Content="&#xE72C;"
                            Style="{StaticResource ToolbarIconButton}"
                            ToolTip="Refresh"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Breadcrumb path row -->
        <Border Grid.Row="1" Background="#FF212124" Padding="14,0,12,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="#FF73737A" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Assets" FontSize="12" Foreground="#FF9A9AA1"
                           FontFamily="Segoe UI Variable Text, Segoe UI" VerticalAlignment="Center"/>
                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                           Foreground="#FF73737A" VerticalAlignment="Center" Margin="7,1,7,0"/>
                <TextBlock Text="Models" FontSize="12" Foreground="#FFE9E9ED"
                           FontFamily="Segoe UI Variable Text, Segoe UI" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Category Tabs -->
        <Border Grid.Row="2" Background="#FF212124" Padding="14,2,12,12">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="MeshesTab" Content="Meshes" GroupName="AssetType"
                             IsChecked="True" Style="{StaticResource CategoryPill}"
                             Checked="AssetTypeTab_Checked"/>
                <RadioButton x:Name="ModelsTab" Content="Models" GroupName="AssetType"
                             Style="{StaticResource CategoryPill}"
                             Checked="AssetTypeTab_Checked"/>
                <RadioButton x:Name="TexturesTab" Content="Textures" GroupName="AssetType"
                             Style="{StaticResource CategoryPill}"
                             Checked="AssetTypeTab_Checked"/>
                <RadioButton x:Name="MaterialsTab" Content="Materials" GroupName="AssetType"
                             Style="{StaticResource CategoryPill}"
                             Checked="AssetTypeTab_Checked"/>
            </StackPanel>
        </Border>

        <!-- Asset tile grid -->
        <ListBox x:Name="AssetList" Grid.Row="3"
                 Background="Transparent" BorderThickness="0"
                 Padding="10,0,10,10"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemContainerStyle="{StaticResource AssetItemStyle}"
                 SelectionChanged="AssetList_SelectionChanged"
                 MouseDoubleClick="AssetList_MouseDoubleClick">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ContextMenu>
                <ContextMenu Background="#FF161618" BorderBrush="#FF3A3A3E">
                    <MenuItem Header="Open / Edit" Click="ContextMenu_Open_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="#FF6C5CE7"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Add to Scene" Click="ContextMenu_AddToScene_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Foreground="#FF4EC9B0"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open in Asset Browser" Click="ContextMenu_OpenInBrowser_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" Foreground="#FF569CD6"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Delete" Click="ContextMenu_Delete_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#FFCE9178"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="92">
                        <!-- Square preview area -->
                        <Border Background="#FF1A1A1C" CornerRadius="10"
                                Width="84" Height="84" HorizontalAlignment="Center">
                            <Grid>
                                <!-- Glyph fallback (shown when the item has no real Thumbnail) -->
                                <TextBlock Text="{Binding IconCode}" FontFamily="Segoe MDL2 Assets"
                                           FontSize="34" Foreground="{Binding IconColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- Real preview (texture image / color swatch / material sphere).
                                     ImageBrush with a null source is transparent, so the glyph shows through. -->
                                <Border CornerRadius="10">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- Centered label -->
                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#FFC8C8CE"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="84"
                                   Margin="0,7,0,0"/>
                        <TextBlock Text="{Binding TypeName}" FontSize="10" Foreground="#FF73737A"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
