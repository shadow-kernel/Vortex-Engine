<UserControl x:Class="Editor.Editors.WorldEditor.Components.GamePreview.GamePreviewView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:Editor.Editors.WorldEditor.Components.GamePreview"
mc:Ignorable="d" 
d:DesignHeight="400" d:DesignWidth="600">

    <UserControl.Resources>
        <Style x:Key="ViewTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9A9AA1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3FA9F5"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E9E9ED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9A9AA1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33333A"/>
                                <Setter Property="Foreground" Value="#E9E9ED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6C5CE7"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9A9AA1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33333A"/>
                                <Setter Property="Foreground" Value="#E9E9ED"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6C5CE7"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#161618"/>
            <Setter Property="Foreground" Value="#E9E9ED"/>
            <Setter Property="BorderBrush" Value="#2C2C32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="18"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path x:Name="Chevron" Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Stroke="#9A9AA1"
                                                      StrokeThickness="1.3"
                                                      StrokeEndLineCap="Round"
                                                      StrokeStartLineCap="Round"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,4,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#1F1F22"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#33333A"/>
                                                <Setter TargetName="Chevron" Property="Stroke" Value="#E9E9ED"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#6C5CE7"/>
                                                <Setter TargetName="Chevron" Property="Stroke" Value="#6C5CE7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,20,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDown"
                                        Background="#232327"
                                        BorderBrush="#33333A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer Margin="2">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E9E9ED"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#28282C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6C5CE7"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Outer Grid to allow overlay on top of everything -->
    <Grid>
        <Border Background="#212124">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="ToolbarRow" Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="22"/>
                </Grid.RowDefinitions>

                <!-- Toolbar (hidden in Game/Play mode for a clean game view) -->
                <Border x:Name="ViewportToolbar" Grid.Row="0" Background="#1A1A1C">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left side tools -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="6,3">
                        <!-- Transform tools pill -->
                        <Border Background="#161618" CornerRadius="9" BorderBrush="#2C2C32" BorderThickness="1" Padding="2,1">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="MoveToolBtn" Content="&#xE759;" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="Move Tool (W)" Click="OnMoveToolClick"/>
                                <Button x:Name="RotateToolBtn" Content="&#xE7AD;" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="Rotate Tool (E)" Click="OnRotateToolClick"/>
                                <Button x:Name="ScaleToolBtn" Content="&#xE740;" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="Scale Tool (R)" Click="OnScaleToolClick"/>
                            </StackPanel>
                        </Border>
                        <!-- Snap / grid pill -->
                        <Border Background="#161618" CornerRadius="9" BorderBrush="#2C2C32" BorderThickness="1" Padding="2,1" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="GridToggleBtn" Content="&#xE8B3;" Style="{StaticResource ToolToggleButtonStyle}"
                                              ToolTip="Toggle Grid (G)" IsChecked="True" Checked="OnGridToggle" Unchecked="OnGridToggle"/>
                                <ToggleButton x:Name="SnapToggleBtn" Content="&#xE81E;" Style="{StaticResource ToolToggleButtonStyle}"
                                              ToolTip="Toggle Snap" Checked="OnSnapToggle" Unchecked="OnSnapToggle"/>
                            </StackPanel>
                        </Border>
                        <!-- View options pill -->
                        <Border Background="#161618" CornerRadius="9" BorderBrush="#2C2C32" BorderThickness="1" Padding="2,1" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ViewModeBtn" Content="&#xE71E;" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="2D/3D View"/>
                                <ToggleButton x:Name="GizmosToggleBtn" Content="&#xE7B3;" Style="{StaticResource ToolToggleButtonStyle}"
                                              ToolTip="Toggle Gizmos" IsChecked="True" Checked="OnGizmosToggle" Unchecked="OnGizmosToggle"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Center: Viewport Layout Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Layout pill -->
                        <Border Background="#161618" CornerRadius="9" BorderBrush="#2C2C32" BorderThickness="1" Padding="2,1">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="SingleViewBtn" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="Single View" Click="OnSingleViewClick" Foreground="#6C5CE7">
                                    <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                </Button>
                                <Button x:Name="SplitVerticalBtn" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="Split Vertical (Left/Right)" Click="OnSplitVerticalClick">
                                    <TextBlock Text="&#xE746;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                </Button>
                                <Button x:Name="SplitHorizontalBtn" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="Split Horizontal (Top/Bottom)" Click="OnSplitHorizontalClick">
                                    <TextBlock Text="&#xE745;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                </Button>
                                <Button x:Name="QuadViewBtn" Style="{StaticResource ToolButtonStyle}"
                                        ToolTip="Quad View (2x2)" Click="OnQuadViewClick">
                                    <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Camera Selector -->
                        <TextBlock Text="View:" Foreground="#73737A" VerticalAlignment="Center"
                                   FontSize="10" Margin="10,0,5,0"/>
                        <ComboBox x:Name="CameraSelector" Style="{StaticResource DarkComboBoxStyle}"
                                  Width="120" SelectionChanged="OnCameraSelectionChanged">
                            <ComboBoxItem Content="Free Camera" IsSelected="True" Style="{StaticResource DarkComboBoxItemStyle}"/>
                        </ComboBox>

                        <!-- PIP Preview Button -->
                        <Button x:Name="ShowPipButton" Style="{StaticResource ToolButtonStyle}"
                                ToolTip="Show Camera Preview (PIP)" Click="OnShowPipClick"
                                Margin="6,0,0,0">
                            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </Button>
                    </StackPanel>
                    
                    <!-- Right: Play Mode Indicator -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,3">
                        <Border x:Name="PlayModeBadge" Background="#306C5CE7" CornerRadius="8"
                                Padding="8,3" Margin="4,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="10" Foreground="#6C5CE7" Margin="0,0,4,0"/>
                                <TextBlock Text="PLAY MODE" Foreground="#6C5CE7"
                                           FontSize="9" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="FlyModeBadge" Background="#306FA8DC" CornerRadius="8"
                                Padding="6,3" Visibility="Collapsed">
                            <TextBlock Text="FLY" Foreground="#6FA8DC" FontSize="9" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- External-window banner (Row 0): always shown while the game runs in the standalone
                 window. It's part of the editor window (not a floating Popup), so it never covers the
                 game window. -->
            <Border x:Name="ExternalBanner" Grid.Row="0" Background="#241F3A" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="#9C8CFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Läuft im externen Fenster" Foreground="#EDEBFF" FontSize="12"
                               FontWeight="SemiBold" FontFamily="Segoe UI Variable Text, Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock Text="— das Spiel läuft im separaten Fenster (dort: ESC pausiert, Stop schließt)"
                               Foreground="#9A95B8" FontSize="11" FontFamily="Segoe UI Variable Text, Segoe UI"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Preview Area with Split Views -->
            <Border Grid.Row="1" Background="#1A1A1A">
                <Grid x:Name="ViewportContainer">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="MainViewportColumn" Width="*"/>
                        <ColumnDefinition x:Name="SplitColumn" Width="0"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="TopViewportRow" Height="*"/>
                        <RowDefinition x:Name="BottomViewportRow" Height="0"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Main Viewport (always visible) -->
                    <Border x:Name="MainViewportPanel" Grid.Column="0" Grid.Row="0" 
                            Grid.RowSpan="2" Background="#1A1A1A" Margin="1"
                            BorderBrush="#363640" BorderThickness="1"
                            MouseDown="OnMainViewportClick">
                        <Grid>
                            <local:ViewportHost x:Name="ViewportHostElement"/>
                            <!-- Main viewport label -->
                            <Border VerticalAlignment="Top" HorizontalAlignment="Left" 
                                    Background="#80000000" CornerRadius="0,0,4,0" Padding="8,4" Margin="0">
                                <TextBlock x:Name="MainViewportLabel" Text="Perspective" 
                                           Foreground="#AAAAAA" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Split Separator (vertical) -->
                    <GridSplitter x:Name="VerticalSplitter" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                  Width="4" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                  Background="#363640" Visibility="Collapsed" Cursor="SizeWE"/>
                    
                    <!-- Secondary Viewport Panel (for Split View) -->
                    <Border x:Name="SecondaryViewportPanel" Grid.Column="1" Grid.Row="0" 
                            Background="#1A1A1A" BorderBrush="#363640" BorderThickness="1"
                            Visibility="Collapsed" Margin="1"
                            MouseDown="OnSecondaryViewportClick">
                        <Grid>
                            <!-- Header with camera selector -->
                            <Border VerticalAlignment="Top" Background="#28282C" Height="28">
                                <Grid Margin="4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE714;" FontFamily="Segoe MDL2 Assets" 
                                               Foreground="#3FA9F5" FontSize="12" VerticalAlignment="Center" Margin="4,0"/>
                                    <ComboBox x:Name="SecondaryViewCameraSelector" Grid.Column="1" 
                                              Style="{StaticResource DarkComboBoxStyle}" 
                                              Margin="4,0" SelectionChanged="OnSecondaryViewCameraChanged">
                                        <ComboBoxItem Content="Select Camera..." IsSelected="True" Style="{StaticResource DarkComboBoxItemStyle}"/>
                                    </ComboBox>
                                    <Button Grid.Column="2" Style="{StaticResource ToolButtonStyle}" 
                                            ToolTip="Close Split View" Click="OnCloseSecondaryView">
                                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                    </Button>
                                </Grid>
                            </Border>
                            
                            <!-- Secondary viewport content - Image for rendered camera view -->
                            <Border Background="#0A0A0A" Margin="0,28,0,0">
                                <Grid>
                                    <!-- Rendered image from camera -->
                                    <Image x:Name="SecondaryViewportImage" Stretch="Fill"/>
                                    
                                    <!-- Overlay info when no camera selected -->
                                    <StackPanel x:Name="SecondaryViewportOverlayInfo" 
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="SecondaryViewCameraInfo" 
                                                   Text="Select a camera" 
                                                   Foreground="#73737A" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                        <TextBlock x:Name="SecondaryViewDetails" 
                                                   Text="Use the dropdown above to select a camera" 
                                                   Foreground="#44444C" FontSize="10" Margin="0,8,0,0"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <!-- View label -->
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left" 
                                            Background="#80000000" CornerRadius="0,0,4,0" Padding="8,4">
                                        <TextBlock x:Name="SecondaryViewLabel" Text="Top" 
                                                   Foreground="#AAAAAA" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Third Viewport Panel (for Quad View - Bottom Left) -->
                    <Border x:Name="ThirdViewportPanel" Grid.Column="0" Grid.Row="1" 
                            Background="#1A1A1A" BorderBrush="#363640" BorderThickness="1"
                            Visibility="Collapsed" Margin="1"
                            MouseDown="OnThirdViewportClick">
                        <Grid>
                            <Border VerticalAlignment="Top" Background="#28282C" Height="28">
                                <Grid Margin="4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE714;" FontFamily="Segoe MDL2 Assets" 
                                               Foreground="#27AE60" FontSize="12" VerticalAlignment="Center" Margin="4,0"/>
                                    <ComboBox x:Name="ThirdViewCameraSelector" Grid.Column="1" 
                                              Style="{StaticResource DarkComboBoxStyle}" 
                                              Margin="4,0" SelectionChanged="OnThirdViewCameraChanged">
                                        <ComboBoxItem Content="Select Camera..." IsSelected="True" Style="{StaticResource DarkComboBoxItemStyle}"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Background="#0A0A0A" Margin="0,28,0,0">
                                <Grid>
                                    <Image x:Name="ThirdViewportImage" Stretch="Fill"/>
                                    <StackPanel x:Name="ThirdViewportOverlayInfo" 
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="ThirdViewInfo" Text="Select a camera" 
                                                   Foreground="#73737A" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left" 
                                            Background="#80000000" CornerRadius="0,0,4,0" Padding="8,4">
                                        <TextBlock x:Name="ThirdViewLabel" Text="No Camera" 
                                                   Foreground="#AAAAAA" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Fourth Viewport Panel (for Quad View - Bottom Right) -->
                    <Border x:Name="FourthViewportPanel" Grid.Column="1" Grid.Row="1" 
                            Background="#1A1A1A" BorderBrush="#363640" BorderThickness="1"
                            Visibility="Collapsed" Margin="1"
                            MouseDown="OnFourthViewportClick">
                        <Grid>
                            <Border VerticalAlignment="Top" Background="#28282C" Height="28">
                                <Grid Margin="4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE714;" FontFamily="Segoe MDL2 Assets" 
                                               Foreground="#E74C3C" FontSize="12" VerticalAlignment="Center" Margin="4,0"/>
                                    <ComboBox x:Name="FourthViewCameraSelector" Grid.Column="1" 
                                              Style="{StaticResource DarkComboBoxStyle}" 
                                              Margin="4,0" SelectionChanged="OnFourthViewCameraChanged">
                                        <ComboBoxItem Content="Select Camera..." IsSelected="True" Style="{StaticResource DarkComboBoxItemStyle}"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Background="#0A0A0A" Margin="0,28,0,0">
                                <Grid>
                                    <Image x:Name="FourthViewportImage" Stretch="Fill"/>
                                    <StackPanel x:Name="FourthViewportOverlayInfo" 
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="FourthViewInfo" Text="Select a camera" 
                                                   Foreground="#73737A" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left" 
                                            Background="#80000000" CornerRadius="0,0,4,0" Padding="8,4">
                                        <TextBlock x:Name="FourthViewLabel" Text="No Camera" 
                                                   Foreground="#AAAAAA" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- PIP is now handled by CameraPreviewOverlay in WorldEditorView -->
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="#28282C">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText" Grid.Column="0" Text="FPS: 60 | Draw Calls: 0 | Vertices: 0" 
                               Foreground="#73737A" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ResolutionText" Grid.Column="1" Text="1920 x 1080" 
                               Foreground="#73737A" FontSize="10" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
    <!-- (The external-window banner is the confined Row-0 Border above — NOT a Popup, so it never
         floats over the standalone game window.) -->
</Grid>
</UserControl>
