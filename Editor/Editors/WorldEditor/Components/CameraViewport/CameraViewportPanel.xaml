<UserControl x:Class="Editor.Editors.WorldEditor.Components.CameraViewport.CameraViewportPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600"
             Background="#FF1E1E1E">
    
    <UserControl.Resources>
        <Style x:Key="ViewportButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FF808080"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3C3C3C"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ActiveViewportButton" TargetType="Button" BasedOn="{StaticResource ViewportButton}">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FF9B59B6"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FF252526" BorderBrush="#FF3C3C3C" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Camera Selection (Game Cameras Only) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0">
                    <TextBlock Text="View as:" Foreground="#FF808080" VerticalAlignment="Center" 
                               FontSize="11" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CameraSelector" Width="150" 
                              Background="#FF1E1E1E" Foreground="#FFC5C5C5"
                              BorderBrush="#FF3C3C3C" FontSize="11"
                              SelectionChanged="CameraSelector_SelectionChanged">
                        <ComboBoxItem Content="Free Camera (Editor)" Tag="free" IsSelected="True"/>
                    </ComboBox>
                    
                    <Border Width="1" Background="#FF3C3C3C" Margin="8,4"/>
                    
                    <!-- View Layout Buttons -->
                    <Button x:Name="SingleViewBtn" Style="{StaticResource ActiveViewportButton}" 
                            ToolTip="Single View" Click="SingleView_Click">
                        <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="SplitHorizontalBtn" Style="{StaticResource ViewportButton}" 
                            ToolTip="Split Horizontal" Click="SplitHorizontal_Click">
                        <TextBlock Text="&#xE746;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="QuadViewBtn" Style="{StaticResource ViewportButton}" 
                            ToolTip="Quad View" Click="QuadView_Click">
                        <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                </StackPanel>
                
                <!-- Center: Active Camera Info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="ActiveCameraIcon" Text="&#xE722;" FontFamily="Segoe MDL2 Assets" 
                               FontSize="12" Foreground="#FF569CD6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock x:Name="ActiveCameraName" Text="Editor Camera" 
                               Foreground="#FFC5C5C5" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CameraPositionText" Text=" (0.0, 2.0, -5.0)" 
                               Foreground="#FF606060" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Right: Input Mode Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0">
                    <Border x:Name="InputModeBadge" Background="#40569CD6" CornerRadius="3" 
                            Padding="6,2" Margin="0,0,4,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" 
                                       FontSize="10" Foreground="#FF569CD6" Margin="0,0,4,0"/>
                            <TextBlock x:Name="InputModeText" Text="FLY MODE" 
                                       Foreground="#FF569CD6" FontSize="9" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <Button x:Name="InputSettingsBtn" Style="{StaticResource ViewportButton}" 
                            ToolTip="Input Settings" Click="InputSettings_Click">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Viewport Container -->
        <Grid x:Name="ViewportContainer" Grid.Row="1" Background="#FF1A1A1A">
            <!-- Single viewport by default, will be modified for split views -->
            <Border x:Name="MainViewport" Background="#FF0A0A0A" Margin="1">
                <Grid>
                    <!-- Viewport overlay for camera info -->
                    <Border x:Name="ViewportOverlay" VerticalAlignment="Top" HorizontalAlignment="Left" 
                            Background="#80000000" CornerRadius="0,0,4,0" Padding="8,4">
                        <StackPanel>
                            <TextBlock x:Name="ViewportLabel" Text="Perspective" 
                                       Foreground="#FFFFFFFF" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ViewportStats" Text="FPS: 60 | Draw: 0" 
                                       Foreground="#FF808080" FontSize="9"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Camera Preview Pip (Picture-in-Picture) -->
                    <Border x:Name="CameraPreviewPip" 
                            VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Width="200" Height="120" Margin="8"
                            Background="#FF1E1E1E" BorderBrush="#FF9B59B6" BorderThickness="2"
                            CornerRadius="4" Visibility="Collapsed">
                        <Grid>
                            <Border Background="#FF0A0A0A" CornerRadius="2" Margin="2">
                                <TextBlock Text="Main Camera Preview" 
                                           Foreground="#FF606060" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border VerticalAlignment="Top" HorizontalAlignment="Left" 
                                    Background="#809B59B6" CornerRadius="0,2,4,0" Padding="4,2">
                                <TextBlock Text="MAIN CAM" Foreground="White" FontSize="8" FontWeight="Bold"/>
                            </Border>
                            <Button VerticalAlignment="Top" HorizontalAlignment="Right" 
                                    Background="Transparent" BorderThickness="0" Margin="2"
                                    ToolTip="Close Preview" Click="ClosePipPreview_Click">
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="10" Foreground="#FF808080"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
