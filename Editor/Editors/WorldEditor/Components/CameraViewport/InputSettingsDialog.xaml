<Window x:Class="Editor.Editors.WorldEditor.Components.CameraViewport.InputSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input Settings" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E" 
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF9B59B6"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
        </Style>

        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FF808080"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="120"/>
        </Style>

        <Style x:Key="KeyBindButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3C3C3C"/>
                    <Setter Property="BorderBrush" Value="#FF569CD6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="0.1"/>
            <Setter Property="Maximum" Value="20"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="20" 
                               Foreground="#FF9B59B6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Input Configuration" FontSize="16" FontWeight="SemiBold" 
                               Foreground="#FFC5C5C5" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Camera Movement Section -->
                <TextBlock Text="CAMERA MOVEMENT" Style="{StaticResource SectionHeader}"/>
                <Border Background="#FF252526" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Forward" Style="{StaticResource PropertyLabel}"/>
                            <Button x:Name="ForwardKeyBtn" Grid.Column="1" Content="W" 
                                    Style="{StaticResource KeyBindButton}" Click="KeyBind_Click" Tag="Forward"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Backward" Style="{StaticResource PropertyLabel}"/>
                            <Button x:Name="BackwardKeyBtn" Grid.Column="1" Content="S" 
                                    Style="{StaticResource KeyBindButton}" Click="KeyBind_Click" Tag="Backward"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Left" Style="{StaticResource PropertyLabel}"/>
                            <Button x:Name="LeftKeyBtn" Grid.Column="1" Content="A" 
                                    Style="{StaticResource KeyBindButton}" Click="KeyBind_Click" Tag="Left"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Right" Style="{StaticResource PropertyLabel}"/>
                            <Button x:Name="RightKeyBtn" Grid.Column="1" Content="D" 
                                    Style="{StaticResource KeyBindButton}" Click="KeyBind_Click" Tag="Right"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Up" Style="{StaticResource PropertyLabel}"/>
                            <Button x:Name="UpKeyBtn" Grid.Column="1" Content="E" 
                                    Style="{StaticResource KeyBindButton}" Click="KeyBind_Click" Tag="Up"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Down" Style="{StaticResource PropertyLabel}"/>
                            <Button x:Name="DownKeyBtn" Grid.Column="1" Content="Q" 
                                    Style="{StaticResource KeyBindButton}" Click="KeyBind_Click" Tag="Down"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sprint" Style="{StaticResource PropertyLabel}"/>
                            <Button x:Name="SprintKeyBtn" Grid.Column="1" Content="Shift" 
                                    Style="{StaticResource KeyBindButton}" Click="KeyBind_Click" Tag="Sprint"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Speed Settings -->
                <TextBlock Text="SPEED SETTINGS" Style="{StaticResource SectionHeader}"/>
                <Border Background="#FF252526" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Move Speed" Style="{StaticResource PropertyLabel}"/>
                            <Slider x:Name="MoveSpeedSlider" Grid.Column="1" Style="{StaticResource SliderStyle}"
                                    Value="5" ValueChanged="MoveSpeed_Changed"/>
                            <TextBlock x:Name="MoveSpeedValue" Grid.Column="2" Text="5.0" 
                                       Foreground="#FFC5C5C5" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Look Sensitivity" Style="{StaticResource PropertyLabel}"/>
                            <Slider x:Name="LookSpeedSlider" Grid.Column="1" Style="{StaticResource SliderStyle}"
                                    Minimum="0.05" Maximum="1" Value="0.2" ValueChanged="LookSpeed_Changed"/>
                            <TextBlock x:Name="LookSpeedValue" Grid.Column="2" Text="0.2" 
                                       Foreground="#FFC5C5C5" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sprint Multiplier" Style="{StaticResource PropertyLabel}"/>
                            <Slider x:Name="SprintMultSlider" Grid.Column="1" Style="{StaticResource SliderStyle}"
                                    Minimum="1" Maximum="5" Value="2.5" ValueChanged="SprintMult_Changed"/>
                            <TextBlock x:Name="SprintMultValue" Grid.Column="2" Text="2.5" 
                                       Foreground="#FFC5C5C5" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Main Camera Input -->
                <TextBlock Text="MAIN CAMERA INPUT" Style="{StaticResource SectionHeader}"/>
                <Border Background="#FF252526" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="These inputs will be forwarded to the Main Camera during play mode."
                                   Foreground="#FF606060" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        
                        <CheckBox x:Name="EnableGameInputCheck" Content="Enable Game Input Forwarding" 
                                  Foreground="#FFC5C5C5" IsChecked="True" Margin="0,4"/>
                        
                        <CheckBox x:Name="LockCursorInPlayCheck" Content="Lock Cursor in Play Mode" 
                                  Foreground="#FFC5C5C5" IsChecked="True" Margin="0,4"/>
                        
                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Input Target" Style="{StaticResource PropertyLabel}"/>
                            <ComboBox x:Name="InputTargetCombo" Grid.Column="1" 
                                      Background="#FF1E1E1E" Foreground="#FFC5C5C5"
                                      BorderBrush="#FF3C3C3C" FontSize="11">
                                <ComboBoxItem Content="Main Camera" IsSelected="True"/>
                                <ComboBoxItem Content="Selected Entity"/>
                                <ComboBoxItem Content="Player Controller"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mouse Settings -->
                <TextBlock Text="MOUSE SETTINGS" Style="{StaticResource SectionHeader}"/>
                <Border Background="#FF252526" CornerRadius="4" Padding="12">
                    <StackPanel>
                        <CheckBox x:Name="InvertYCheck" Content="Invert Y-Axis" 
                                  Foreground="#FFC5C5C5" Margin="0,4"/>
                        <CheckBox x:Name="InvertXCheck" Content="Invert X-Axis" 
                                  Foreground="#FFC5C5C5" Margin="0,4"/>
                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fly Mode Button" Style="{StaticResource PropertyLabel}"/>
                            <ComboBox x:Name="FlyModeButtonCombo" Grid.Column="1" 
                                      Background="#FF1E1E1E" Foreground="#FFC5C5C5"
                                      BorderBrush="#FF3C3C3C" FontSize="11">
                                <ComboBoxItem Content="Right Mouse Button" IsSelected="True"/>
                                <ComboBoxItem Content="Middle Mouse Button"/>
                                <ComboBoxItem Content="Left Mouse Button"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Buttons -->
        <Border Grid.Row="1" Background="#FF252526" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reset to Defaults" Width="120" Padding="8,6"
                        Background="#FF3C3C3C" Foreground="#FFC5C5C5" BorderThickness="0"
                        Margin="0,0,8,0" Click="ResetDefaults_Click"/>
                <Button Content="Apply" Width="80" Padding="8,6"
                        Background="#FF569CD6" Foreground="White" BorderThickness="0"
                        Margin="0,0,8,0" Click="Apply_Click"/>
                <Button Content="Close" Width="80" Padding="8,6"
                        Background="#FF3C3C3C" Foreground="#FFC5C5C5" BorderThickness="0"
                        Click="Close_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
