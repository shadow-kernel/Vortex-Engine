<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.TransformInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="150" d:DesignWidth="280"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9AA1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="64"/>
        </Style>

        <!-- Rounded pill numeric field (Apple-style) -->
        <Style x:Key="VectorInput" TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="CaretBrush" Value="#FF6C5CE7"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="8" Background="#FF161618"
                                BorderBrush="#FF33333A" BorderThickness="1" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="6,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF4A4A52"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF6C5CE7"/>
                                <Setter TargetName="bd" Property="Background" Value="#FF1B1B1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AxisLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FF232327" CornerRadius="12" Padding="14" Margin="0,0,0,10">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE759;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#FF9A9AA1"
                               VerticalAlignment="Center" Margin="0,0,9,0"/>
                    <TextBlock Text="Transform" FontSize="13.5" FontWeight="SemiBold"
                               Foreground="#FFE9E9ED" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                           Foreground="#FF73737A" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- Position -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Position" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="X" Foreground="#FFE0686B" Style="{StaticResource AxisLabel}"/>
                    <TextBox x:Name="PosX" Style="{StaticResource VectorInput}"
                             TextChanged="Position_TextChanged"/>
                    <TextBlock Text="Y" Foreground="#FF7DBE6A" Style="{StaticResource AxisLabel}" Margin="9,0,5,0"/>
                    <TextBox x:Name="PosY" Style="{StaticResource VectorInput}"
                             TextChanged="Position_TextChanged"/>
                    <TextBlock Text="Z" Foreground="#FF6FA8DC" Style="{StaticResource AxisLabel}" Margin="9,0,5,0"/>
                    <TextBox x:Name="PosZ" Style="{StaticResource VectorInput}"
                             TextChanged="Position_TextChanged"/>
                </StackPanel>
            </Grid>

            <!-- Rotation -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Rotation" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="X" Foreground="#FFE0686B" Style="{StaticResource AxisLabel}"/>
                    <TextBox x:Name="RotX" Style="{StaticResource VectorInput}"
                             TextChanged="Rotation_TextChanged"/>
                    <TextBlock Text="Y" Foreground="#FF7DBE6A" Style="{StaticResource AxisLabel}" Margin="9,0,5,0"/>
                    <TextBox x:Name="RotY" Style="{StaticResource VectorInput}"
                             TextChanged="Rotation_TextChanged"/>
                    <TextBlock Text="Z" Foreground="#FF6FA8DC" Style="{StaticResource AxisLabel}" Margin="9,0,5,0"/>
                    <TextBox x:Name="RotZ" Style="{StaticResource VectorInput}"
                             TextChanged="Rotation_TextChanged"/>
                </StackPanel>
            </Grid>

            <!-- Scale -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Scale" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="X" Foreground="#FFE0686B" Style="{StaticResource AxisLabel}"/>
                    <TextBox x:Name="ScaleX" Style="{StaticResource VectorInput}"
                             TextChanged="Scale_TextChanged"/>
                    <TextBlock Text="Y" Foreground="#FF7DBE6A" Style="{StaticResource AxisLabel}" Margin="9,0,5,0"/>
                    <TextBox x:Name="ScaleY" Style="{StaticResource VectorInput}"
                             TextChanged="Scale_TextChanged"/>
                    <TextBlock Text="Z" Foreground="#FF6FA8DC" Style="{StaticResource AxisLabel}" Margin="9,0,5,0"/>
                    <TextBox x:Name="ScaleZ" Style="{StaticResource VectorInput}"
                             TextChanged="Scale_TextChanged"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
