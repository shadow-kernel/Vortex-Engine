<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.CameraInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="280"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9AA1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="95"/>
        </Style>

        <!-- Rounded pill numeric field (Apple-style) -->
        <Style x:Key="ValueInput" TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="CaretBrush" Value="#FF6C5CE7"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="8" Background="#FF161618"
                                BorderBrush="#FF33333A" BorderThickness="1" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="6,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF4A4A52"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF6C5CE7"/>
                                <Setter TargetName="bd" Property="Background" Value="#FF1B1B1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource Vortex.ComboBox}">
            <Setter Property="Background" Value="#FF161618"/>
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="BorderBrush" Value="#FF33333A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource Vortex.CheckBox}">
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="BorderBrush" Value="#FF33333A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="#FF73737A"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FF232327" CornerRadius="12" Padding="14" Margin="0,0,0,10">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock x:Name="CameraIcon" Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                           FontSize="15" Foreground="#FF9A9AA1"
                           VerticalAlignment="Center" Margin="0,0,9,0"/>
                <TextBlock Text="Camera" FontSize="13.5" FontWeight="SemiBold"
                           Foreground="#FFE9E9ED" VerticalAlignment="Center"/>
                <TextBlock x:Name="CameraTypeLabel" Text="" FontSize="11"
                           Foreground="#FF9A9AA1" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Camera Type -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Camera Type" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="CameraTypeCombo" Grid.Column="1" Style="{StaticResource ComboBoxStyle}"
                          SelectionChanged="CameraType_SelectionChanged">
                    <ComboBoxItem Content="Game Camera" Tag="0"/>
                    <ComboBoxItem Content="Main Camera" Tag="1"/>
                </ComboBox>
            </Grid>

            <!-- Main Camera Warning -->
            <TextBlock x:Name="MainCameraWarning"
                       Text="Only one Main Camera allowed per scene!"
                       Foreground="#FFFF6B6B" FontSize="11"
                       Margin="0,2,0,4" Visibility="Collapsed"/>

            <!-- Projection Settings -->
            <TextBlock Text="PROJECTION" Style="{StaticResource SectionHeader}"/>

            <!-- Projection Type -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Projection" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="ProjectionCombo" Grid.Column="1" Style="{StaticResource ComboBoxStyle}"
                          SelectionChanged="Projection_SelectionChanged">
                    <ComboBoxItem Content="Perspective"/>
                    <ComboBoxItem Content="Orthographic"/>
                </ComboBox>
            </Grid>

            <!-- Field of View (Perspective) -->
            <Grid x:Name="FovPanel" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Field of View" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="FovInput" Style="{StaticResource ValueInput}" Width="60"
                             TextChanged="Fov_TextChanged"/>
                    <TextBlock Text="deg" Foreground="#FF73737A" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Orthographic Size -->
            <Grid x:Name="OrthoPanel" Margin="0,5" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ortho Size" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="OrthoSizeInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         HorizontalAlignment="Left" TextChanged="OrthoSize_TextChanged"/>
            </Grid>

            <!-- Clipping Planes -->
            <TextBlock Text="CLIPPING PLANES" Style="{StaticResource SectionHeader}"/>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Near" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="NearClipInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         HorizontalAlignment="Left" TextChanged="NearClip_TextChanged"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Far" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="FarClipInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         HorizontalAlignment="Left" TextChanged="FarClip_TextChanged"/>
            </Grid>

            <!-- Rendering Settings -->
            <TextBlock Text="RENDERING" Style="{StaticResource SectionHeader}"/>

            <!-- Background Color -->
            <Grid x:Name="BackgroundColorPanel" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Background" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BackgroundColorButton" Style="{StaticResource ColorButton}"
                            Click="BackgroundColor_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ColorPreview" Background="#1A1A33"
                                        BorderBrush="#FF33333A" BorderThickness="1" CornerRadius="7"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="ColorValueText" Text="(0.0, 0.0, 0.3)"
                               Foreground="#FF73737A" VerticalAlignment="Center" Margin="9,0,0,0" FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- Depth (Render Order) -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Render Order" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="DepthInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         HorizontalAlignment="Left" TextChanged="Depth_TextChanged" ToolTip="Lower values render first (0 = first)"/>
            </Grid>

            <!-- Preview Button -->
            <Button x:Name="PreviewButton" Content="&#xE722;  Preview Camera View" Margin="0,14,0,0"
                    Foreground="#FF9A9AA1" BorderThickness="0"
                    Padding="8,7" FontSize="11.5" Cursor="Hand" FontFamily="Segoe UI"
                    Click="PreviewCamera_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#FF28282C"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="pbBd" Background="{TemplateBinding Background}" CornerRadius="8"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="pbBd" Property="Background" Value="#FF33333A"/>
                                            <Setter Property="Foreground" Value="#FFE9E9ED"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
