<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.CameraInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="280"
             Background="Transparent">
    
    <UserControl.Resources>
        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF808080"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="95"/>
        </Style>
        
        <Style x:Key="ValueInput" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FF606060"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#FF2D2D30" CornerRadius="4" Padding="10" Margin="0,5">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="CameraIcon" Text="&#xE722;" FontFamily="Segoe MDL2 Assets" 
                           FontSize="16" Foreground="#9B59B6" 
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Camera" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#FFC5C5C5" VerticalAlignment="Center"/>
                <TextBlock x:Name="CameraTypeLabel" Text="" FontSize="10" 
                           Foreground="#FF808080" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
            
            <!-- Camera Type -->
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Camera Type" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="CameraTypeCombo" Grid.Column="1" Style="{StaticResource ComboBoxStyle}"
                          SelectionChanged="CameraType_SelectionChanged">
                    <ComboBoxItem Content="Game Camera" Tag="0"/>
                    <ComboBoxItem Content="Main Camera" Tag="1"/>
                </ComboBox>
            </Grid>
            
            <!-- Main Camera Warning -->
            <TextBlock x:Name="MainCameraWarning" 
                       Text="Only one Main Camera allowed per scene!"
                       Foreground="#FFFF6B6B" FontSize="10" 
                       Margin="0,2,0,4" Visibility="Collapsed"/>
            
            <!-- Projection Settings -->
            <TextBlock Text="PROJECTION" Style="{StaticResource SectionHeader}"/>
            
            <!-- Projection Type -->
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Projection" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="ProjectionCombo" Grid.Column="1" Style="{StaticResource ComboBoxStyle}"
                          SelectionChanged="Projection_SelectionChanged">
                    <ComboBoxItem Content="Perspective"/>
                    <ComboBoxItem Content="Orthographic"/>
                </ComboBox>
            </Grid>
            
            <!-- Field of View (Perspective) -->
            <Grid x:Name="FovPanel" Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Field of View" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="FovInput" Style="{StaticResource ValueInput}" Width="60"
                             TextChanged="Fov_TextChanged"/>
                    <TextBlock Text="deg" Foreground="#FF606060" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
            
            <!-- Orthographic Size -->
            <Grid x:Name="OrthoPanel" Margin="0,4" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ortho Size" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="OrthoSizeInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         TextChanged="OrthoSize_TextChanged"/>
            </Grid>
            
            <!-- Clipping Planes -->
            <TextBlock Text="CLIPPING PLANES" Style="{StaticResource SectionHeader}"/>
            
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Near" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="NearClipInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         TextChanged="NearClip_TextChanged"/>
            </Grid>
            
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Far" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="FarClipInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         TextChanged="FarClip_TextChanged"/>
            </Grid>
            
            <!-- Rendering Settings -->
            <TextBlock Text="RENDERING" Style="{StaticResource SectionHeader}"/>
            
            <!-- Background Color -->
            <Grid x:Name="BackgroundColorPanel" Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Background" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BackgroundColorButton" Style="{StaticResource ColorButton}"
                            Click="BackgroundColor_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ColorPreview" Background="#1A1A33" 
                                        BorderBrush="#FF3C3C3C" BorderThickness="1" CornerRadius="2"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="ColorValueText" Text="(0.0, 0.0, 0.3)" 
                               Foreground="#FF606060" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="10"/>
                </StackPanel>
            </Grid>
            
            <!-- Depth (Render Order) -->
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Render Order" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="DepthInput" Grid.Column="1" Style="{StaticResource ValueInput}" Width="60"
                         TextChanged="Depth_TextChanged" ToolTip="Lower values render first (0 = first)"/>
            </Grid>
            
            <!-- Preview Button -->
            <Button x:Name="PreviewButton" Content="&#xE722;  Preview Camera View" Margin="0,12,0,0"
                    Background="#FF3C3C3C" Foreground="#FFC5C5C5" BorderThickness="0"
                    Padding="8,6" FontSize="11" Cursor="Hand" FontFamily="Segoe UI"
                    Click="PreviewCamera_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4C4C4C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
