<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.MeshRendererInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300"
             Background="Transparent">
    
    <UserControl.Resources>
        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF808080"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        
        <Style x:Key="PropertyComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        
        <Style x:Key="PropertyCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#FF2D2D30" CornerRadius="4" Padding="10" Margin="0,5">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="&#xE809;" FontFamily="Segoe MDL2 Assets" 
                           FontSize="16" Foreground="#FF4EC9B0" 
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Mesh Renderer" FontSize="14" FontWeight="SemiBold" 
                           Foreground="#FFC5C5C5" VerticalAlignment="Center"/>
                <CheckBox x:Name="EnabledCheckBox" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                          Margin="20,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Mesh Selection -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Mesh" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="MeshComboBox" Grid.Column="1" 
                          Style="{StaticResource PropertyComboBox}"
                          SelectionChanged="MeshComboBox_SelectionChanged">
                    <ComboBoxItem Content="None"/>
                    <ComboBoxItem Content="Cube"/>
                    <ComboBoxItem Content="Sphere"/>
                    <ComboBoxItem Content="Plane"/>
                    <ComboBoxItem Content="Cylinder"/>
                    <ComboBoxItem Content="Cone"/>
                </ComboBox>
                <Button Grid.Column="2" Content="&#xE8E5;" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Foreground="#FF808080"
                        Padding="6" FontSize="12" ToolTip="Select Mesh"
                        Click="SelectMeshButton_Click"/>
            </Grid>
            
            <!-- Material Selection -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Material" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="MaterialComboBox" Grid.Column="1" 
                          Style="{StaticResource PropertyComboBox}"
                          SelectionChanged="MaterialComboBox_SelectionChanged">
                    <ComboBoxItem Content="Default"/>
                </ComboBox>
                <Button Grid.Column="2" Content="&#xE8E5;" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Foreground="#FF808080"
                        Padding="6" FontSize="12" ToolTip="Select Material"
                        Click="SelectMaterialButton_Click"/>
            </Grid>
            
            <!-- Shadow Options -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Shadows" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="CastShadowsCheckBox" Content="Cast" 
                              Style="{StaticResource PropertyCheckBox}" Margin="0,0,15,0"
                              IsChecked="{Binding CastShadows, Mode=TwoWay}"/>
                    <CheckBox x:Name="ReceiveShadowsCheckBox" Content="Receive" 
                              Style="{StaticResource PropertyCheckBox}"
                              IsChecked="{Binding ReceiveShadows, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
