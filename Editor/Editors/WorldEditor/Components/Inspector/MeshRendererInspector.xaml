<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.MeshRendererInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="300"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9AA1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="PropertyComboBox" TargetType="ComboBox" BasedOn="{StaticResource Vortex.ComboBox}">
            <Setter Property="Background" Value="#FF161618"/>
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF33333A"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PropertyCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFC8C8CE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FF232327" CornerRadius="12" Padding="14" Margin="0,0,0,10">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#xE809;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="#FF9A9AA1"
                               VerticalAlignment="Center" Margin="0,0,9,0"/>
                    <TextBlock Text="Mesh Renderer" FontSize="13.5" FontWeight="SemiBold"
                               Foreground="#FFE9E9ED" VerticalAlignment="Center"/>
                    <CheckBox x:Name="EnabledCheckBox" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                              Margin="14,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="RemoveBtn" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        Foreground="#FFB76B7E" Background="Transparent" BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0" ToolTip="Remove component" Click="Remove_Click"/>
            </Grid>

            <!-- Mesh Selection -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Mesh" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="MeshComboBox" Grid.Column="1"
                          Style="{StaticResource PropertyComboBox}"
                          SelectionChanged="MeshComboBox_SelectionChanged">
                    <ComboBoxItem Content="None"/>
                    <ComboBoxItem Content="Cube"/>
                    <ComboBoxItem Content="Sphere"/>
                    <ComboBoxItem Content="Plane"/>
                    <ComboBoxItem Content="Cylinder"/>
                    <ComboBoxItem Content="Cone"/>
                </ComboBox>
                <Button Grid.Column="2" Content="&#xE8E5;" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Foreground="#FF9A9AA1"
                        Padding="6" FontSize="12" ToolTip="Select Mesh"
                        Click="SelectMeshButton_Click"/>
            </Grid>

            <!-- Material Slot: shows the assigned .vmat, is a .vmat drop target, double-click opens the Material Editor -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Material" Style="{StaticResource PropertyLabel}"/>
                <Border x:Name="MaterialSlot" Grid.Column="1" Height="28" CornerRadius="4"
                        Background="#FF161618" BorderBrush="#FF33333A" BorderThickness="1"
                        AllowDrop="True" DragEnter="MaterialSlot_DragOver" DragOver="MaterialSlot_DragOver"
                        Drop="MaterialSlot_Drop" MouseLeftButtonDown="MaterialSlot_MouseLeftButtonDown"
                        ToolTip="Drop a .vmat here — double-click to open it in the Material Editor">
                    <TextBlock x:Name="MaterialNameText" Text="Default" FontSize="12"
                               Foreground="#FFE9E9ED" VerticalAlignment="Center"
                               Margin="8,0" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Button Grid.Column="2" Content="&#xE8E5;" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Foreground="#FF9A9AA1"
                        Padding="6" FontSize="12" ToolTip="Select Material"
                        Click="SelectMaterialButton_Click"/>
                <Button Grid.Column="3" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0" Foreground="#FF9A9AA1"
                        Padding="6" FontSize="12" ToolTip="Clear material (engine default)"
                        Click="ClearMaterialButton_Click"/>
            </Grid>

            <!-- Shadow Options -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Shadows" Style="{StaticResource PropertyLabel}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="CastShadowsCheckBox" Content="Cast"
                              Style="{StaticResource PropertyCheckBox}" Margin="0,0,15,0"
                              IsChecked="{Binding CastShadows, Mode=TwoWay}"/>
                    <CheckBox x:Name="ReceiveShadowsCheckBox" Content="Receive"
                              Style="{StaticResource PropertyCheckBox}"
                              IsChecked="{Binding ReceiveShadows, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>

            <!-- Render layer (#175): 0 World / 1 First-Person viewmodel / 2 Third-Person only -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Layer" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="RenderLayerComboBox" Grid.Column="1" Height="26"
                          Background="#FF161618" Foreground="#FFE9E9ED" BorderBrush="#FF33333A"
                          VerticalContentAlignment="Center" FontSize="12"
                          SelectionChanged="RenderLayerComboBox_Changed">
                    <ComboBoxItem Content="World"
                                  ToolTip="Default: rendered for every camera, casts shadows."/>
                    <ComboBoxItem Content="First-Person (viewmodel)"
                                  ToolTip="Renders after the world with its own FOV and cleared depth: never clips through walls, casts no shadows. For first-person arms/weapons. Hidden in the editor build view (use the FP Preview view mode or the FP toolbar toggle to see it)."/>
                    <ComboBoxItem Content="Third-Person only"
                                  ToolTip="What OTHERS see: rendered normally in the editor, but hidden for the local player while playing. For the world-body of a first-person character."/>
                </ComboBox>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
