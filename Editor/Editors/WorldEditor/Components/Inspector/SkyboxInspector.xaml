<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.SkyboxInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <Border Background="#2D2D30" CornerRadius="4" Padding="10" Margin="0,5,0,0">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="&#xE81A;" FontFamily="Segoe MDL2 Assets" 
                           FontSize="16" Foreground="#87CEEB" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" x:Name="HeaderText" Text="Skybox" 
                           FontSize="14" FontWeight="SemiBold" Foreground="#C5C5C5" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="2" x:Name="EnabledCheckBox" IsChecked="True" 
                          VerticalAlignment="Center" Checked="EnabledCheckBox_Changed" Unchecked="EnabledCheckBox_Changed"/>
            </Grid>
            
            <!-- Skybox Type -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Type" Foreground="#999" VerticalAlignment="Center"/>
                <ComboBox x:Name="SkyboxTypeCombo" Grid.Column="1" 
                          SelectionChanged="SkyboxTypeCombo_SelectionChanged">
                    <ComboBoxItem Content="Solid Color"/>
                    <ComboBoxItem Content="Gradient"/>
                    <ComboBoxItem Content="Cubemap"/>
                    <ComboBoxItem Content="Texture (HDR)"/>
                </ComboBox>
            </Grid>
            
            <!-- Ambient Intensity -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ambient" Foreground="#999" VerticalAlignment="Center" ToolTip="Ambient Light Intensity"/>
                <Slider x:Name="AmbientSlider" Grid.Column="1" Minimum="0" Maximum="2" Value="0.3"
                        VerticalAlignment="Center" ValueChanged="AmbientSlider_ValueChanged"/>
                <TextBox x:Name="AmbientValue" Grid.Column="2" Text="0.3" 
                         Background="#1E1E1E" Foreground="#CCC" BorderBrush="#555" 
                         TextAlignment="Center" VerticalContentAlignment="Center"
                         TextChanged="AmbientValue_TextChanged"/>
            </Grid>
            
            <!-- Exposure -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Exposure" Foreground="#999" VerticalAlignment="Center"/>
                <Slider x:Name="ExposureSlider" Grid.Column="1" Minimum="0.1" Maximum="4" Value="1"
                        VerticalAlignment="Center" ValueChanged="ExposureSlider_ValueChanged"/>
                <TextBox x:Name="ExposureValue" Grid.Column="2" Text="1.0" 
                         Background="#1E1E1E" Foreground="#CCC" BorderBrush="#555" 
                         TextAlignment="Center" VerticalContentAlignment="Center"
                         TextChanged="ExposureValue_TextChanged"/>
            </Grid>
            
            <Separator Background="#3C3C3C" Margin="0,10"/>
            
            <!-- Top/Sky Color -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Sky Color" Foreground="#999" VerticalAlignment="Center"/>
                <Border x:Name="TopColorPreview" Grid.Column="1" Height="24" CornerRadius="2" 
                        Background="#6699E5" BorderBrush="#555" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="TopColorPreview_Click"/>
            </Grid>
            
            <!-- Horizon Color (Gradient only) -->
            <Grid x:Name="HorizonColorRow" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Horizon Color" Foreground="#999" VerticalAlignment="Center"/>
                <Border x:Name="HorizonColorPreview" Grid.Column="1" Height="24" CornerRadius="2" 
                        Background="#99B2D9" BorderBrush="#555" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="HorizonColorPreview_Click"/>
            </Grid>
            
            <!-- Bottom/Ground Color (Gradient only) -->
            <Grid x:Name="BottomColorRow" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ground Color" Foreground="#999" VerticalAlignment="Center"/>
                <Border x:Name="BottomColorPreview" Grid.Column="1" Height="24" CornerRadius="2" 
                        Background="#33334C" BorderBrush="#555" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="BottomColorPreview_Click"/>
            </Grid>
            
            <!-- Cubemap Path (Cubemap only) -->
            <Grid x:Name="CubemapRow" Margin="0,5" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cubemap" Foreground="#999" VerticalAlignment="Center"/>
                <TextBox x:Name="CubemapPathText" Grid.Column="1" 
                         Background="#1E1E1E" Foreground="#CCC" BorderBrush="#555" 
                         IsReadOnly="True" Text="(Not set)"/>
                <Button Grid.Column="2" Content="..." Width="30" Margin="5,0,0,0"
                        Click="BrowseCubemap_Click"/>
            </Grid>
            
            <!-- Texture Path (for HDR/Equirectangular) -->
            <Grid x:Name="TextureRow" Margin="0,5" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Texture" Foreground="#999" VerticalAlignment="Center" 
                           ToolTip="HDR or Equirectangular panorama texture (required)"/>
                <TextBox x:Name="TexturePathText" Grid.Column="1" 
                         Background="#1E1E1E" Foreground="#CCC" BorderBrush="#555" 
                         IsReadOnly="True" Text="(Not set)"/>
                <Button Grid.Column="2" Content="..." Width="30" Margin="5,0,0,0"
                        Click="BrowseTexture_Click" ToolTip="Select texture from project"/>
            </Grid>
            
            <!-- Skybox Mesh Path (for 3D Skybox) - OPTIONAL -->
            <Grid x:Name="MeshRow" Margin="0,5" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mesh (opt.)" Foreground="#666" VerticalAlignment="Center"
                           ToolTip="Optional: Custom skybox mesh. If empty, uses built-in sphere."/>
                <TextBox x:Name="MeshPathText" Grid.Column="1" 
                         Background="#1E1E1E" Foreground="#666" BorderBrush="#444" 
                         IsReadOnly="True" Text="(Built-in Sphere)"/>
                <Button Grid.Column="2" Content="..." Width="30" Margin="5,0,0,0"
                        Click="BrowseMesh_Click" ToolTip="Optional: Use custom mesh instead of built-in sphere"/>
            </Grid>
            
            <!-- Info Text -->
            <TextBlock x:Name="InfoText" 
                       Text="?? Select a texture (PNG, JPG, HDR) for the skybox. A built-in sphere is used automatically." 
                       Foreground="#666" FontSize="10" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
