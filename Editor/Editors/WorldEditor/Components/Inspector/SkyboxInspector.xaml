<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.SkyboxInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="PropertyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9AA1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Rounded pill numeric field (Apple-style) -->
        <Style x:Key="ValueInput" TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="CaretBrush" Value="#FF6C5CE7"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="8" Background="#FF161618"
                                BorderBrush="#FF33333A" BorderThickness="1" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="6,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF4A4A52"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF6C5CE7"/>
                                <Setter TargetName="bd" Property="Background" Value="#FF1B1B1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Read-only path field (left-aligned pill) -->
        <Style x:Key="PathInput" TargetType="TextBox" BasedOn="{StaticResource ValueInput}">
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#FFC8C8CE"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource Vortex.ComboBox}">
            <Setter Property="Background" Value="#FF161618"/>
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="BorderBrush" Value="#FF33333A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="#FF9A9AA1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bbBd" Background="#FF28282C" CornerRadius="7"
                                BorderBrush="#FF33333A" BorderThickness="1" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bbBd" Property="Background" Value="#FF33333A"/>
                                <Setter Property="Foreground" Value="#FFE9E9ED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#FF232327" CornerRadius="12" Padding="14" Margin="0,0,0,10">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="&#xE81A;" FontFamily="Segoe MDL2 Assets"
                           FontSize="15" Foreground="#FF9A9AA1" VerticalAlignment="Center" Margin="0,0,9,0"/>
                <TextBlock Grid.Column="1" x:Name="HeaderText" Text="Skybox"
                           FontSize="13.5" FontWeight="SemiBold" Foreground="#FFE9E9ED" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="2" x:Name="EnabledCheckBox" IsChecked="True"
                          VerticalAlignment="Center" Checked="EnabledCheckBox_Changed" Unchecked="EnabledCheckBox_Changed"/>
                <Button Grid.Column="3" x:Name="RemoveBtn" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        Foreground="#FFB76B7E" Background="Transparent" BorderThickness="0" Cursor="Hand"
                        VerticalAlignment="Center" Margin="12,0,0,0" ToolTip="Remove component" Click="Remove_Click"/>
            </Grid>

            <!-- Skybox Type -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Type" Style="{StaticResource PropertyLabel}"/>
                <ComboBox x:Name="SkyboxTypeCombo" Grid.Column="1" Style="{StaticResource ComboBoxStyle}"
                          SelectionChanged="SkyboxTypeCombo_SelectionChanged">
                    <ComboBoxItem Content="Solid Color"/>
                    <ComboBoxItem Content="Gradient"/>
                    <ComboBoxItem Content="Cubemap"/>
                    <ComboBoxItem Content="Texture (HDR)"/>
                </ComboBox>
            </Grid>

            <!-- Ambient Intensity -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ambient" Style="{StaticResource PropertyLabel}" ToolTip="Ambient Light Intensity"/>
                <Slider x:Name="AmbientSlider" Grid.Column="1" Minimum="0" Maximum="2" Value="0.3"
                        VerticalAlignment="Center" ValueChanged="AmbientSlider_ValueChanged"/>
                <TextBox x:Name="AmbientValue" Grid.Column="2" Text="0.3"
                         Style="{StaticResource ValueInput}" Margin="8,0,0,0"
                         TextChanged="AmbientValue_TextChanged"/>
            </Grid>

            <!-- Exposure -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Exposure" Style="{StaticResource PropertyLabel}"/>
                <Slider x:Name="ExposureSlider" Grid.Column="1" Minimum="0.1" Maximum="4" Value="1"
                        VerticalAlignment="Center" ValueChanged="ExposureSlider_ValueChanged"/>
                <TextBox x:Name="ExposureValue" Grid.Column="2" Text="1.0"
                         Style="{StaticResource ValueInput}" Margin="8,0,0,0"
                         TextChanged="ExposureValue_TextChanged"/>
            </Grid>

            <Separator Background="#FF2C2C32" Margin="0,12"/>

            <!-- Top/Sky Color -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Sky Color" Style="{StaticResource PropertyLabel}"/>
                <Border x:Name="TopColorPreview" Grid.Column="1" Height="26" CornerRadius="8"
                        Background="#6699E5" BorderBrush="#FF33333A" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="TopColorPreview_Click"/>
            </Grid>

            <!-- Horizon Color (Gradient only) -->
            <Grid x:Name="HorizonColorRow" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Horizon Color" Style="{StaticResource PropertyLabel}"/>
                <Border x:Name="HorizonColorPreview" Grid.Column="1" Height="26" CornerRadius="8"
                        Background="#99B2D9" BorderBrush="#FF33333A" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="HorizonColorPreview_Click"/>
            </Grid>

            <!-- Bottom/Ground Color (Gradient only) -->
            <Grid x:Name="BottomColorRow" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ground Color" Style="{StaticResource PropertyLabel}"/>
                <Border x:Name="BottomColorPreview" Grid.Column="1" Height="26" CornerRadius="8"
                        Background="#33334C" BorderBrush="#FF33333A" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="BottomColorPreview_Click"/>
            </Grid>

            <!-- Cubemap Path (Cubemap only) -->
            <Grid x:Name="CubemapRow" Margin="0,5" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cubemap" Style="{StaticResource PropertyLabel}"/>
                <TextBox x:Name="CubemapPathText" Grid.Column="1" Style="{StaticResource PathInput}"
                         IsReadOnly="True" Text="(Not set)"/>
                <Button Grid.Column="2" Content="..." Margin="6,0,0,0" Style="{StaticResource BrowseButton}"
                        Click="BrowseCubemap_Click"/>
            </Grid>

            <!-- Texture Path (for HDR/Equirectangular) -->
            <Grid x:Name="TextureRow" Margin="0,5" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Texture" Style="{StaticResource PropertyLabel}"
                           ToolTip="HDR or Equirectangular panorama texture (required)"/>
                <TextBox x:Name="TexturePathText" Grid.Column="1" Style="{StaticResource PathInput}"
                         IsReadOnly="True" Text="(Not set)"/>
                <Button Grid.Column="2" Content="..." Margin="6,0,0,0" Style="{StaticResource BrowseButton}"
                        Click="BrowseTexture_Click" ToolTip="Select texture from project"/>
            </Grid>

            <!-- Skybox Mesh Path (for 3D Skybox) - OPTIONAL -->
            <Grid x:Name="MeshRow" Margin="0,5" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mesh (opt.)" Foreground="#FF73737A" FontSize="12" VerticalAlignment="Center"
                           ToolTip="Optional: Custom skybox mesh. If empty, uses built-in sphere."/>
                <TextBox x:Name="MeshPathText" Grid.Column="1" Style="{StaticResource PathInput}"
                         Foreground="#FF73737A" IsReadOnly="True" Text="(Built-in Sphere)"/>
                <Button Grid.Column="2" Content="..." Margin="6,0,0,0" Style="{StaticResource BrowseButton}"
                        Click="BrowseMesh_Click" ToolTip="Optional: Use custom mesh instead of built-in sphere"/>
            </Grid>

            <!-- Info Text -->
            <TextBlock x:Name="InfoText"
                       Text="?? Select a texture (PNG, JPG, HDR) for the skybox. A built-in sphere is used automatically."
                       Foreground="#FF73737A" FontSize="10.5" TextWrapping="Wrap" Margin="0,12,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
