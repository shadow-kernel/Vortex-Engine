<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.DynamicInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Editor.Editors.WorldEditor.Components.Inspector"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="280">

    <UserControl.Resources>
        <Style x:Key="PropertyLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9A9AA1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="70"/>
        </Style>

        <!-- Rounded pill input field (Apple-style) -->
        <Style x:Key="PropertyTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FF161618"/>
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="CaretBrush" Value="#FF6C5CE7"/>
            <Setter Property="BorderBrush" Value="#FF33333A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="6,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF4A4A52"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF6C5CE7"/>
                                <Setter TargetName="bd" Property="Background" Value="#FF1B1B1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VectorInputStyle" TargetType="TextBox" BasedOn="{StaticResource PropertyTextBoxStyle}">
            <Setter Property="Width" Value="56"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Full-width accent pill button (Apple-style) -->
        <Style x:Key="ComponentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6C5CE7"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF7D6EF0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF5B4BD6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#FF212124">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Scrollable Content -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="12">
                <StackPanel x:Name="ComponentsPanel" Margin="2">
                    <!-- No Selection Message -->
                    <TextBlock x:Name="NoSelectionText"
                               Text="Select an entity to view properties"
                               Foreground="#FF73737A"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,24"/>

                    <!-- Entity Header (hidden when no selection) -->
                    <Border x:Name="EntityHeader" Background="#FF232327" CornerRadius="12" Padding="14"
                            Margin="0,0,0,10" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="EntityActiveCheckBox" Grid.Column="0" IsChecked="True"
                                      VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="EntityNameTextBox" Grid.Column="1"
                                     Style="{StaticResource PropertyTextBoxStyle}"
                                     FontSize="13" FontWeight="SemiBold"
                                     TextChanged="EntityNameTextBox_TextChanged"/>
                            <ComboBox x:Name="EntityTagComboBox" Grid.Column="2" Width="84" Margin="10,0,0,0"
                                      Background="#FF161618" Foreground="#FFE9E9ED" BorderBrush="#FF33333A"
                                      Height="28" VerticalContentAlignment="Center" FontSize="12">
                                <ComboBoxItem Content="Untagged" IsSelected="True"/>
                                <ComboBoxItem Content="Player"/>
                                <ComboBoxItem Content="Enemy"/>
                                <ComboBoxItem Content="MainCamera"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Dynamic Components Container -->
                    <StackPanel x:Name="DynamicComponentsContainer"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Add Component Button -->
            <Border Grid.Row="1" Background="#FF1A1A1C" BorderBrush="#FF2C2C32" BorderThickness="0,1,0,0" Padding="12">
                <Button x:Name="AddComponentButton" Content="Add Component"
                        Style="{StaticResource ComponentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Visibility="Collapsed"
                        Click="AddComponentButton_Click"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
