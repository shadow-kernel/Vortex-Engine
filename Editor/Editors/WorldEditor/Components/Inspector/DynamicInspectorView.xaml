<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.DynamicInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Editor.Editors.WorldEditor.Components.Inspector"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="280">

    <UserControl.Resources>
        <Style x:Key="PropertyLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="70"/>
        </Style>

        <Style x:Key="PropertyTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#C5C5C5"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3FA9F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VectorInputStyle" TargetType="TextBox" BasedOn="{StaticResource PropertyTextBoxStyle}">
            <Setter Property="Width" Value="50"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComponentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3FA9F5"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5BB8F7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2F8DD6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#252526">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Scrollable Content -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="8">
                <StackPanel x:Name="ComponentsPanel" Margin="4">
                    <!-- No Selection Message -->
                    <TextBlock x:Name="NoSelectionText" 
                               Text="Select an entity to view properties" 
                               Foreground="#606060" 
                               HorizontalAlignment="Center" 
                               Margin="0,20"/>
                    
                    <!-- Entity Header (hidden when no selection) -->
                    <Border x:Name="EntityHeader" Background="#2D2D30" CornerRadius="4" Padding="8" 
                            Margin="0,0,0,8" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="EntityActiveCheckBox" Grid.Column="0" IsChecked="True" 
                                      VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="EntityNameTextBox" Grid.Column="1" 
                                     Style="{StaticResource PropertyTextBoxStyle}" 
                                     FontSize="12" FontWeight="SemiBold"
                                     TextChanged="EntityNameTextBox_TextChanged"/>
                            <ComboBox x:Name="EntityTagComboBox" Grid.Column="2" Width="80" Margin="8,0,0,0">
                                <ComboBoxItem Content="Untagged" IsSelected="True"/>
                                <ComboBoxItem Content="Player"/>
                                <ComboBoxItem Content="Enemy"/>
                                <ComboBoxItem Content="MainCamera"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Dynamic Components Container -->
                    <StackPanel x:Name="DynamicComponentsContainer"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Add Component Button -->
            <Border Grid.Row="1" Background="#1E1E1E" Padding="8">
                <Button x:Name="AddComponentButton" Content="Add Component" 
                        Style="{StaticResource ComponentButtonStyle}" 
                        HorizontalAlignment="Stretch"
                        Visibility="Collapsed"
                        Click="AddComponentButton_Click"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
