<UserControl x:Class="Editor.Editors.WorldEditor.Components.Inspector.ScriptInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="300"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#FFE9E9ED"/>
            <Setter Property="Background" Value="#FF2A2A30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}" BorderBrush="#FF3A3A42" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#FF33333A"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#FF232327" CornerRadius="12" Padding="14" Margin="0,0,0,10">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#FFDCDCAA"
                               VerticalAlignment="Center" Margin="0,0,9,0"/>
                    <TextBlock Text="Script" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFE9E9ED" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="DetachBtn" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        Foreground="#FFB76B7E" Background="Transparent" BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Right" ToolTip="Remove this script" Click="Detach_Click"/>
            </Grid>

            <!-- Class -->
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Class" Foreground="#FF9A9AA1" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="ClassText" Grid.Column="1" Text="—" Foreground="#FFE9E9ED" FontSize="12.5"
                           FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Grid>

            <!-- Path -->
            <TextBlock x:Name="PathText" Text="" Foreground="#FF73737A" FontSize="11" Margin="0,6,0,0"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Missing warning -->
            <StackPanel x:Name="WarnPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#FFE0A33A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Script file not found in project" Foreground="#FFE0A33A" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Public script fields (#47): rows are built in code from the reflected type. -->
            <StackPanel x:Name="FieldsPanel" Margin="0,10,0,0"/>
            <TextBlock x:Name="FieldsHint" Text="" Foreground="#FF73737A" FontSize="10.5" Margin="0,6,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Open in Visual Studio" Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="OpenVs_Click"/>
                <Button Content="Change…" Style="{StaticResource GhostBtn}" Click="Change_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
