<UserControl x:Class="Editor.Editors.WorldEditor.Components.SceneHierarchy.SceneHierarchyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="250">

    <UserControl.Resources>
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#C5C5C5"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,4,8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <Grid>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                           Foreground="#606060" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3FA9F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SceneTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#C5C5C5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                    Padding="{TemplateBinding Padding}" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0" 
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" Width="16" Height="16">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Padding="4">
                                                    <Path x:Name="Arrow" Data="M0,0 L4,4 L0,8 Z" 
                                                          Fill="#606060" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0" CenterX="2" CenterY="4"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90" CenterX="2" CenterY="4"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="#C5C5C5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <TextBlock x:Name="Icon" Grid.Column="1" Text="&#xE734;" FontFamily="Segoe MDL2 Assets" 
                                               FontSize="12" Foreground="#3FA9F5" VerticalAlignment="Center" Margin="2,0,6,0"/>
                                    <ContentPresenter Grid.Column="2" x:Name="PART_Header" ContentSource="Header" 
                                                      HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" 
                                               FontSize="10" Foreground="#505050" VerticalAlignment="Center" Margin="4,0"
                                               Visibility="Collapsed" x:Name="VisibilityIcon" ToolTip="Toggle Visibility"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="16,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="Icon" Property="Text" Value="&#xE80B;"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="#808080"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#37373D"/>
                                <Setter TargetName="VisibilityIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                                <Setter TargetName="VisibilityIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3C3C3C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#252526" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#2D2D30" CornerRadius="4,4,0,0" Padding="8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Hierarchy" Foreground="#C5C5C5" FontSize="11" 
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="&#xE710;" Style="{StaticResource AddButtonStyle}" ToolTip="Add Entity"/>
                </Grid>
            </Border>

            <!-- Search Bar -->
            <Border Grid.Row="1" Padding="6,4">
                <TextBox Style="{StaticResource SearchBoxStyle}"/>
            </Border>

            <!-- Scene Tree -->
            <TreeView Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="4,0">
                <TreeViewItem Header="Main Scene" IsExpanded="True" Style="{StaticResource SceneTreeItemStyle}">
                    <TreeViewItem Header="Main Camera" Style="{StaticResource SceneTreeItemStyle}"/>
                    <TreeViewItem Header="Directional Light" Style="{StaticResource SceneTreeItemStyle}"/>
                    <TreeViewItem Header="Player" IsExpanded="True" Style="{StaticResource SceneTreeItemStyle}">
                        <TreeViewItem Header="PlayerMesh" Style="{StaticResource SceneTreeItemStyle}"/>
                        <TreeViewItem Header="PlayerCollider" Style="{StaticResource SceneTreeItemStyle}"/>
                    </TreeViewItem>
                    <TreeViewItem Header="Environment" IsExpanded="True" Style="{StaticResource SceneTreeItemStyle}">
                        <TreeViewItem Header="Ground" Style="{StaticResource SceneTreeItemStyle}"/>
                        <TreeViewItem Header="Skybox" Style="{StaticResource SceneTreeItemStyle}"/>
                        <TreeViewItem Header="Props" Style="{StaticResource SceneTreeItemStyle}">
                            <TreeViewItem Header="Tree_01" Style="{StaticResource SceneTreeItemStyle}"/>
                            <TreeViewItem Header="Rock_01" Style="{StaticResource SceneTreeItemStyle}"/>
                            <TreeViewItem Header="Barrel_01" Style="{StaticResource SceneTreeItemStyle}"/>
                        </TreeViewItem>
                    </TreeViewItem>
                    <TreeViewItem Header="UI Canvas" Style="{StaticResource SceneTreeItemStyle}"/>
                </TreeViewItem>
            </TreeView>
        </Grid>
    </Border>
</UserControl>
