<UserControl x:Class="Editor.Editors.WorldEditor.WorldEditorView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:Editor.Editors.WorldEditor"
xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
xmlns:headerBar="clr-namespace:Editor.Editors.WorldEditor.Components.HeaderBar"
xmlns:gamePreview="clr-namespace:Editor.Editors.WorldEditor.Components.GamePreview"
xmlns:fileExplorer="clr-namespace:Editor.Editors.WorldEditor.Components.FileExplorer"
xmlns:sceneHierarchy="clr-namespace:Editor.Editors.WorldEditor.Components.SceneHierarchy"
xmlns:inspector="clr-namespace:Editor.Editors.WorldEditor.Components.Inspector"
xmlns:environment="clr-namespace:Editor.Editors.WorldEditor.Components.Environment"
xmlns:historyLog="clr-namespace:Editor.Editors.WorldEditor.Components.HistoryLog"
xmlns:assetBrowser="clr-namespace:Editor.Editors.WorldEditor.Components.AssetBrowser"
xmlns:console="clr-namespace:Editor.Editors.WorldEditor.Components.Console"
xmlns:cameraPreview="clr-namespace:Editor.Editors.WorldEditor.Components.CameraPreview"
xmlns:themes="clr-namespace:Editor.Editors.WorldEditor.Themes"
mc:Ignorable="d" Background="#1A1A1C"
d:DesignHeight="720" d:DesignWidth="1280">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkDockTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Override focus visual styles to remove white borders -->
            <Style x:Key="{x:Static SystemParameters.FocusVisualStyleKey}">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Rectangle StrokeThickness="0" Stroke="Transparent" Fill="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header Bar (Fixed) — Auto so the slot always tracks HeaderBarView's real
                 content height (currently 48 menu + 32 toolbar = 80px). Hard-coding a number
                 here previously caused the toolbar row to be clipped behind the viewport. -->
            <RowDefinition Height="Auto"/>
            <!-- Dockable Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar (Not Dockable) -->
        <headerBar:HeaderBarView Grid.Row="0"/>

        <!-- AvalonDock DockingManager -->
        <avalonDock:DockingManager x:Name="DockManager" Grid.Row="1"
                                   AllowMixedOrientation="True"
                                   Background="#1A1A1C">
            
            <!-- Use our dark dictionary as AvalonDock's BASE theme so un-templated dock
                 controls (document-pane border, auto-hide flyout, drag overlay) fall back
                 to dark instead of the white GenericTheme. Replaces the old Resources merge. -->
            <avalonDock:DockingManager.Theme>
                <themes:DarkAvalonTheme/>
            </avalonDock:DockingManager.Theme>

            <avalonDock:LayoutRoot>
                <!-- 1:1 Aurora layout: [Scene + File System] | [Viewport + Project/Console] | [Inspector] -->
                <avalonDock:LayoutPanel Orientation="Horizontal">

                    <!-- LEFT: Scene (hierarchy) on top, File System below -->
                    <avalonDock:LayoutAnchorablePaneGroup Orientation="Vertical" DockWidth="230">
                        <avalonDock:LayoutAnchorablePane DockHeight="3*">
                            <avalonDock:LayoutAnchorable Title="Scene" CanClose="False" CanFloat="False" CanAutoHide="False">
                                <sceneHierarchy:SceneHierarchyView/>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                        <avalonDock:LayoutAnchorablePane DockHeight="2*">
                            <avalonDock:LayoutAnchorable Title="File System" CanClose="False" CanFloat="False" CanAutoHide="False">
                                <fileExplorer:FileTreeView/>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutAnchorablePaneGroup>

                    <!-- CENTER: Viewport on top, Project/Console below -->
                    <avalonDock:LayoutPanel Orientation="Vertical" DockWidth="*">
                        <avalonDock:LayoutDocumentPane DockHeight="*">
                            <avalonDock:LayoutDocument Title="Scene" CanClose="False" CanFloat="False">
                                <gamePreview:GamePreviewView/>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                        <avalonDock:LayoutAnchorablePane DockHeight="360">
                            <avalonDock:LayoutAnchorable Title="Project" CanClose="False" CanFloat="False" CanAutoHide="False">
                                <assetBrowser:AssetBrowserView x:Name="AssetBrowser"/>
                            </avalonDock:LayoutAnchorable>
                            <avalonDock:LayoutAnchorable Title="Console" CanClose="False" CanFloat="False" CanAutoHide="False">
                                <console:ConsoleView/>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutPanel>

                    <!-- RIGHT: Inspector + scene Environment (fog/post-FX #27-#29) as tabs, full height -->
                    <avalonDock:LayoutAnchorablePane DockWidth="330">
                        <avalonDock:LayoutAnchorable Title="Inspector" CanClose="False" CanFloat="False" CanAutoHide="False">
                            <inspector:DynamicInspectorView/>
                        </avalonDock:LayoutAnchorable>
                        <avalonDock:LayoutAnchorable Title="Environment" CanClose="False" CanFloat="False" CanAutoHide="False">
                            <environment:EnvironmentView/>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
        
        <!-- Camera Preview Popup - Positioned over GamePreviewView -->
        <Popup x:Name="CameraPreviewPopup" 
               Placement="Custom"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="True">
            <cameraPreview:CameraPreviewOverlay x:Name="CameraPreviewOverlay"/>
        </Popup>

        <!-- Edge masks: cover the thin light hairline AvalonDock/DWM leaves at the very
             left/right window border in the dock region (maximized, borderless). Dark-on-dark
             so invisible; IsHitTestVisible=False so they never block viewport/panel input. -->
        <Rectangle Grid.Row="1" Width="3" HorizontalAlignment="Left" Fill="#1A1A1C" IsHitTestVisible="False"/>
        <Rectangle Grid.Row="1" Width="2" HorizontalAlignment="Right" Fill="#1A1A1C" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
