<UserControl x:Class="Editor.Editors.WorldEditor.WorldEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Editor.Editors.WorldEditor"
             xmlns:headerBar="clr-namespace:Editor.Editors.WorldEditor.Components.HeaderBar"
             xmlns:gamePreview="clr-namespace:Editor.Editors.WorldEditor.Components.GamePreview"
             xmlns:fileExplorer="clr-namespace:Editor.Editors.WorldEditor.Components.FileExplorer"
             xmlns:sceneHierarchy="clr-namespace:Editor.Editors.WorldEditor.Components.SceneHierarchy"
             xmlns:inspector="clr-namespace:Editor.Editors.WorldEditor.Components.Inspector"
             mc:Ignorable="d" Background="#1E1E1E"
             d:DesignHeight="720" d:DesignWidth="1280">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header Bar -->
            <RowDefinition Height="60"/>
            <!-- Main Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <headerBar:HeaderBarView Grid.Row="0"/>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left/Center Content -->
                <ColumnDefinition Width="*"/>
                <!-- Right Panel (Hierarchy + Inspector) -->
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left/Center: Game Preview + File Explorer -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <!-- Game Preview -->
                    <RowDefinition Height="*"/>
                    <!-- File Explorer Panel -->
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- Game Preview Area -->
                <gamePreview:GamePreviewView Grid.Row="0" Margin="4,4,2,2"/>

                <!-- Splitter -->
                <GridSplitter Grid.Row="0" Height="4" VerticalAlignment="Bottom" 
                              HorizontalAlignment="Stretch" Background="Transparent" 
                              Cursor="SizeNS" ResizeDirection="Rows"/>

                <!-- File Explorer Panel (Tree + Explorer) -->
                <Grid Grid.Row="1" Margin="4,2,2,4">
                    <Grid.ColumnDefinitions>
                        <!-- File Tree -->
                        <ColumnDefinition Width="200"/>
                        <!-- Splitter -->
                        <ColumnDefinition Width="4"/>
                        <!-- File Explorer -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- File Tree View -->
                    <fileExplorer:FileTreeView Grid.Column="0"/>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" 
                                  VerticalAlignment="Stretch" Background="Transparent" 
                                  Cursor="SizeWE"/>

                    <!-- File Explorer View -->
                    <fileExplorer:FileExplorerView Grid.Column="2"/>
                </Grid>
            </Grid>

            <!-- Right Panel: Hierarchy + Inspector -->
            <Grid Grid.Column="1" Margin="2,4,4,4">
                <Grid.RowDefinitions>
                    <!-- Scene Hierarchy -->
                    <RowDefinition Height="*"/>
                    <!-- Splitter -->
                    <RowDefinition Height="4"/>
                    <!-- Inspector -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Scene Hierarchy -->
                <sceneHierarchy:SceneHierarchyView Grid.Row="0"/>

                <!-- Splitter -->
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" 
                              VerticalAlignment="Center" Background="Transparent" 
                              Cursor="SizeNS"/>

                <!-- Inspector Panel -->
                <inspector:InspectorView Grid.Row="2"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
